#!/usr/bin/env python3
import argparse
import json
import os
import re
import stat
import sys
from datetime import datetime, timezone
from pathlib import Path

from _rtlib import (
    LIFECYCLE_ORDINAL,
    current_records,
    find_project_root,
    load_agents_doc,
    read_records,
    require_fenced_seat,
)

ROOT = find_project_root("rt-inbox")
STATE_DIR = ROOT / ".roundtable"
MSG_DIR = STATE_DIR / "messages"
INBOX_DIR = STATE_DIR / "inbox"
AGENT_COMPONENT_RE = re.compile(r"^[a-z0-9#_-]+$")
MAIL_HEADER_RE = re.compile(
    r"^\[(?P<from>[a-z0-9#_-]+)→(?P<to>[a-z0-9#_-]+) "
    r"(?P<kind>[^\s\]]+) id=(?P<msg_id>[^\s\]]+)\](?: (?P<body>.*))?$",
    re.IGNORECASE | re.DOTALL,
)


def parse_args():
    parser = argparse.ArgumentParser(prog="rt-inbox")
    parser.add_argument("agent", nargs="?", help="agent or instance to inspect; defaults to inferred sender")
    parser.add_argument("--all", action="store_true", help="include acked messages")
    parser.add_argument(
        "--fenced",
        action="store_true",
        help="require the current Roundtable launcher lease",
    )
    parser.add_argument(
        "--archive-quiet-acks",
        action="store_true",
        help="archive validated quiet acknowledgements for the fenced seat",
    )
    parser.add_argument("-f", "--format", choices=("text", "json"), default="text")
    return parser.parse_args()


def infer_agent_from_codex_thread():
    thread_id = os.environ.get("CODEX_THREAD_ID")
    if not thread_id:
        return ""
    document = load_agents_doc(ROOT, "rt-inbox")
    exact = []
    candidates = []
    for base, raw_config in (document.get("agents") or {}).items():
        config = raw_config if isinstance(raw_config, dict) else {}
        if str(config.get("harness") or base).lower() != "codex":
            continue
        base_name = str(base).lower()
        instances = config.get("instances") or [{"id": base_name}]
        for instance in instances:
            if isinstance(instance, str):
                instance_id = instance.lower()
                session_id = None
            else:
                instance_id = str((instance or {}).get("id") or base_name).lower()
                session_id = (instance or {}).get("session_id")
            candidates.append(instance_id)
            if session_id == thread_id:
                exact.append(instance_id)
    if len(exact) == 1:
        return exact[0]
    return candidates[0] if len(candidates) == 1 else ""


def infer_agent():
    env_from = os.environ.get("RT_FROM", "")
    if env_from:
        return env_from.lower()
    codex_agent = infer_agent_from_codex_thread()
    if codex_agent:
        return codex_agent
    raise SystemExit("rt-inbox: could not infer agent; pass agent or set RT_FROM")


def one_line(value):
    return re.sub(r"\s+", " ", str(value or "")).strip()


def truncate(value, width=80):
    text = one_line(value)
    if len(text) <= width:
        return text
    return text[: width - 3] + "..."


def refs_from_record(record):
    refs = list(record.get("refs") or [])
    if refs:
        return refs
    for part in one_line(record.get("body", "")).split():
        if part.startswith("refs="):
            return [ref for ref in part.removeprefix("refs=").split(",") if ref]
    return []


def mail_timestamp(msg_id, path):
    timestamp = msg_id.split("-", 1)[0]
    try:
        parsed = datetime.strptime(timestamp, "%Y%m%dT%H%M%SZ").replace(tzinfo=timezone.utc)
        return parsed.isoformat(timespec="milliseconds").replace("+00:00", "Z")
    except ValueError:
        return datetime.fromtimestamp(path.stat().st_mtime, timezone.utc).isoformat(
            timespec="milliseconds"
        ).replace("+00:00", "Z")


def read_maildir_records():
    records = []
    if not INBOX_DIR.is_dir():
        return records
    for target_dir in sorted(INBOX_DIR.iterdir()):
        if not target_dir.is_dir() or not AGENT_COMPONENT_RE.fullmatch(target_dir.name):
            continue
        target = target_dir.name.lower()
        paths = []
        for folder in ("new", "cur"):
            directory = target_dir / folder
            if directory.is_dir():
                paths.extend((folder, path) for path in sorted(directory.glob("*.md")))
        for folder, path in paths:
            try:
                content = path.read_text(encoding="utf-8")
            except (OSError, UnicodeError):
                continue
            match = MAIL_HEADER_RE.fullmatch(content)
            if not match:
                continue
            parsed = match.groupdict()
            msg_id = parsed["msg_id"]
            to_agent = parsed["to"].lower()
            kind = parsed["kind"].lower()
            # Drained normal mail is no longer inbox-visible. Drained quiet acks
            # remain fact-source tombstones: without the retired rt-watch there
            # is no separate process to materialize an "acked" ledger event.
            if folder == "cur" and kind != "sync-ack":
                continue
            valid_stems = {msg_id}
            if kind == "sync-ack":
                valid_stems.add(f"ack-{msg_id}")
            if path.stem not in valid_stems or to_agent != target:
                continue
            body = parsed.get("body") or ""
            record = {
                "schema": "roundtable.maildir_message.v1",
                "msg_id": msg_id,
                "event_id": "",
                "ts": mail_timestamp(msg_id, path),
                "from": parsed["from"].lower(),
                "to": to_agent,
                "kind": kind,
                "body": body,
                "rendered_text": content,
                "send_text": None,
                "workspace_ref": None,
                "surface_ref": None,
                "pane_ref": None,
                "submit": "none",
                "lifecycle": folder,
                "refs": [],
                "correlation": {},
                "source": "maildir",
                "maildir_path": str(path),
                "delivery_sources": ["maildir"],
            }
            if record["kind"] == "sync-ack":
                record["refs"] = refs_from_record(record)
            records.append(record)
    return records


def _fsync_directory(path):
    descriptor = os.open(path, os.O_RDONLY)
    try:
        os.fsync(descriptor)
    finally:
        os.close(descriptor)


def archive_quiet_acks(agent):
    inbox = INBOX_DIR / agent
    new_dir = inbox / "new"
    cur_dir = inbox / "cur"
    for directory in (INBOX_DIR, inbox, new_dir):
        if directory.is_symlink():
            raise SystemExit(f"rt-inbox: maildir path is a symlink: {directory}")
        if directory.exists() and not directory.is_dir():
            raise SystemExit(
                f"rt-inbox: maildir path is not a directory: {directory}"
            )
    if not new_dir.exists():
        return 0
    cur_dir.mkdir(parents=True, exist_ok=True)
    if cur_dir.is_symlink() or not cur_dir.is_dir():
        raise SystemExit(f"rt-inbox: invalid archive directory: {cur_dir}")

    candidates = [
        Path(record["maildir_path"])
        for record in read_maildir_records()
        if record.get("to") == agent
        and record.get("kind") == "sync-ack"
        and Path(record.get("maildir_path", "")).parent == new_dir
    ]
    archived = 0
    for source in candidates:
        destination = cur_dir / source.name
        try:
            source_info = source.lstat()
            if not stat.S_ISREG(source_info.st_mode):
                raise OSError(f"quiet acknowledgement is not a regular file: {source}")
            try:
                destination_info = destination.lstat()
            except FileNotFoundError:
                destination_info = None
            if destination_info is None:
                os.link(source, destination, follow_symlinks=False)
                _fsync_directory(cur_dir)
            elif (
                not stat.S_ISREG(destination_info.st_mode)
                or (source_info.st_dev, source_info.st_ino)
                != (destination_info.st_dev, destination_info.st_ino)
            ):
                raise FileExistsError(
                    f"refusing to overwrite quiet acknowledgement archive: "
                    f"{destination}"
                )
            source.unlink()
            _fsync_directory(new_dir)
            archived += 1
        except OSError as error:
            raise SystemExit(
                f"rt-inbox: failed to archive quiet acknowledgement: {error}"
            ) from None
    return archived


def visible_records(agent, include_all):
    ledger_records = read_records(MSG_DIR)
    maildir_records = read_maildir_records()
    acked_refs = set()
    for record in ledger_records:
        if (
            record.get("msg_id")
            and LIFECYCLE_ORDINAL.get(record.get("lifecycle"), -1)
            >= LIFECYCLE_ORDINAL["acked"]
        ):
            acked_refs.add(record["msg_id"])
    for record in [*ledger_records, *maildir_records]:
        if record.get("kind") != "sync-ack":
            continue
        acked_refs.update(refs_from_record(record))

    records = []
    for ledger_record in current_records(ledger_records).values():
        record = dict(ledger_record)
        record["delivery_source"] = "ledger"
        record["delivery_sources"] = ["ledger"]
        records.append(record)
    for maildir_record in maildir_records:
        record = dict(maildir_record)
        record["delivery_source"] = "maildir"
        record["delivery_sources"] = ["maildir"]
        records.append(record)

    records.sort(
        key=lambda item: (
            item.get("ts", ""),
            item.get("msg_id", ""),
            item.get("delivery_source", ""),
        )
    )
    visible = []
    for record in records:
        if (record.get("to") or "").lower() != agent:
            continue
        if record.get("kind") == "sync-ack":
            continue
        if not include_all and record.get("msg_id") in acked_refs:
            continue
        if not include_all and LIFECYCLE_ORDINAL.get(record.get("lifecycle"), -1) >= LIFECYCLE_ORDINAL["acked"]:
            continue
        visible.append(record)
    return visible


def print_text(records):
    for record in records:
        sources = "+".join(record.get("delivery_sources") or ["ledger"])
        print(
            f"{record.get('msg_id', '')}  "
            f"{record.get('from', '')}  "
            f"{record.get('kind', '')}  "
            f"{record.get('lifecycle', '')}  "
            f"[{sources}]  "
            f"{truncate(record.get('body', ''))}"
        )


def main():
    args = parse_args()
    if args.archive_quiet_acks and not args.fenced:
        raise SystemExit("rt-inbox: --archive-quiet-acks requires --fenced")
    fenced_agent = require_fenced_seat(ROOT, "rt-inbox") if args.fenced else ""
    agent = (args.agent or fenced_agent or infer_agent()).lower()
    if fenced_agent and agent != fenced_agent:
        raise SystemExit(
            f"rt-inbox: fenced seat {fenced_agent} cannot inspect {agent}"
        )
    if args.archive_quiet_acks:
        archived = archive_quiet_acks(agent)
        if archived:
            print(
                f"rt-inbox: archived {archived} quiet acknowledgement(s)",
                file=sys.stderr,
            )
    records = visible_records(agent, args.all)
    if args.format == "json":
        print(json.dumps(records, ensure_ascii=False, indent=2))
        return
    print_text(records)


if __name__ == "__main__":
    main()
