#!/usr/bin/env python3
import argparse
import json
import os
import re
import subprocess
from datetime import datetime, timezone
from pathlib import Path

from _rtlib import LIFECYCLE_ORDINAL, current_records, find_project_root, read_records, run_json

TOOL_DIR = Path(__file__).resolve().parent
ROOT = find_project_root("rt-inbox")
STATE_DIR = ROOT / ".roundtable"
RUNTIME = STATE_DIR / "runtime.json"
MSG_DIR = STATE_DIR / "messages"
INBOX_DIR = STATE_DIR / "inbox"
AGENT_COMPONENT_RE = re.compile(r"^[a-z0-9#_-]+$")
MAIL_HEADER_RE = re.compile(
    r"^\[(?P<from>[a-z0-9#_-]+)→(?P<to>[a-z0-9#_-]+) "
    r"(?P<kind>[^\s\]]+) id=(?P<msg_id>[^\s\]]+)\](?: (?P<body>.*))?$",
    re.IGNORECASE | re.DOTALL,
)


def parse_args():
    parser = argparse.ArgumentParser(prog="rt-inbox")
    parser.add_argument("agent", nargs="?", help="agent or instance to inspect; defaults to inferred sender")
    parser.add_argument("--all", action="store_true", help="include acked messages")
    parser.add_argument("-f", "--format", choices=("text", "json"), default="text")
    return parser.parse_args()


def load_runtime(refresh=False):
    if refresh or not RUNTIME.exists() or RUNTIME.stat().st_size == 0:
        subprocess.run([str(TOOL_DIR / "rt-refresh")], check=True, stdout=subprocess.DEVNULL)
    try:
        return json.loads(RUNTIME.read_text())
    except (FileNotFoundError, json.JSONDecodeError):
        return {}


def infer_agent():
    env_from = os.environ.get("RT_FROM", "")
    if env_from:
        return env_from.lower()

    runtime = load_runtime(refresh=False)
    caller_surface = ""
    try:
        caller_surface = (run_json("cmux", "identify", "--json").get("caller") or {}).get("surface_ref") or ""
    except (OSError, subprocess.CalledProcessError, json.JSONDecodeError):
        pass
    for name, agent in (runtime.get("agents") or {}).items():
        if agent.get("surface_ref") == caller_surface:
            return name
    if caller_surface:
        runtime = load_runtime(refresh=True)
        for name, agent in (runtime.get("agents") or {}).items():
            if agent.get("surface_ref") == caller_surface:
                return name
    raise SystemExit("rt-inbox: could not infer agent from current cmux surface; pass agent or set RT_FROM")


def one_line(value):
    return re.sub(r"\s+", " ", str(value or "")).strip()


def truncate(value, width=80):
    text = one_line(value)
    if len(text) <= width:
        return text
    return text[: width - 3] + "..."


def refs_from_record(record):
    refs = list(record.get("refs") or [])
    if refs:
        return refs
    for part in one_line(record.get("body", "")).split():
        if part.startswith("refs="):
            return [ref for ref in part.removeprefix("refs=").split(",") if ref]
    return []


def mail_timestamp(msg_id, path):
    timestamp = msg_id.split("-", 1)[0]
    try:
        parsed = datetime.strptime(timestamp, "%Y%m%dT%H%M%SZ").replace(tzinfo=timezone.utc)
        return parsed.isoformat(timespec="milliseconds").replace("+00:00", "Z")
    except ValueError:
        return datetime.fromtimestamp(path.stat().st_mtime, timezone.utc).isoformat(
            timespec="milliseconds"
        ).replace("+00:00", "Z")


def read_maildir_records():
    records = []
    if not INBOX_DIR.is_dir():
        return records
    for target_dir in sorted(INBOX_DIR.iterdir()):
        if not target_dir.is_dir() or not AGENT_COMPONENT_RE.fullmatch(target_dir.name):
            continue
        target = target_dir.name.lower()
        new_dir = target_dir / "new"
        if not new_dir.is_dir():
            continue
        for path in sorted(new_dir.glob("*.md")):
            try:
                content = path.read_text(encoding="utf-8")
            except (OSError, UnicodeError):
                continue
            match = MAIL_HEADER_RE.fullmatch(content)
            if not match:
                continue
            parsed = match.groupdict()
            msg_id = parsed["msg_id"]
            to_agent = parsed["to"].lower()
            if path.stem != msg_id or to_agent != target:
                continue
            body = parsed.get("body") or ""
            record = {
                "schema": "roundtable.maildir_message.v1",
                "msg_id": msg_id,
                "event_id": "",
                "ts": mail_timestamp(msg_id, path),
                "from": parsed["from"].lower(),
                "to": to_agent,
                "kind": parsed["kind"],
                "body": body,
                "rendered_text": content,
                "send_text": None,
                "workspace_ref": None,
                "surface_ref": None,
                "pane_ref": None,
                "submit": "none",
                "lifecycle": "new",
                "refs": [],
                "correlation": {},
                "source": "maildir",
                "maildir_path": str(path),
                "delivery_sources": ["maildir"],
            }
            if record["kind"] == "sync-ack":
                record["refs"] = refs_from_record(record)
            records.append(record)
    return records


def visible_records(agent, include_all):
    ledger_records = read_records(MSG_DIR)
    maildir_records = read_maildir_records()
    acked_refs = set()
    for record in ledger_records:
        if (
            record.get("msg_id")
            and LIFECYCLE_ORDINAL.get(record.get("lifecycle"), -1)
            >= LIFECYCLE_ORDINAL["acked"]
        ):
            acked_refs.add(record["msg_id"])
    for record in [*ledger_records, *maildir_records]:
        if record.get("kind") != "sync-ack":
            continue
        acked_refs.update(refs_from_record(record))

    records = []
    for ledger_record in current_records(ledger_records).values():
        record = dict(ledger_record)
        record["delivery_source"] = "ledger"
        record["delivery_sources"] = ["ledger"]
        records.append(record)
    for maildir_record in maildir_records:
        record = dict(maildir_record)
        record["delivery_source"] = "maildir"
        record["delivery_sources"] = ["maildir"]
        records.append(record)

    records.sort(
        key=lambda item: (
            item.get("ts", ""),
            item.get("msg_id", ""),
            item.get("delivery_source", ""),
        )
    )
    visible = []
    for record in records:
        if (record.get("to") or "").lower() != agent:
            continue
        if record.get("kind") == "sync-ack":
            continue
        if not include_all and record.get("msg_id") in acked_refs:
            continue
        if not include_all and LIFECYCLE_ORDINAL.get(record.get("lifecycle"), -1) >= LIFECYCLE_ORDINAL["acked"]:
            continue
        visible.append(record)
    return visible


def print_text(records):
    for record in records:
        sources = "+".join(record.get("delivery_sources") or ["ledger"])
        print(
            f"{record.get('msg_id', '')}  "
            f"{record.get('from', '')}  "
            f"{record.get('kind', '')}  "
            f"{record.get('lifecycle', '')}  "
            f"[{sources}]  "
            f"{truncate(record.get('body', ''))}"
        )


def main():
    args = parse_args()
    agent = (args.agent or infer_agent()).lower()
    records = visible_records(agent, args.all)
    if args.format == "json":
        print(json.dumps(records, ensure_ascii=False, indent=2))
        return
    print_text(records)


if __name__ == "__main__":
    main()
