#!/usr/bin/env python3
"""Operational checks for the Roundtable Codex wake path."""

from __future__ import annotations

import argparse
import json
import os
import stat
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

from _rtcodex import (
    AppServerClient,
    DEFAULT_SOCKET,
    RUNTIME_DIR,
    VALIDATED_CODEX_MAX,
    VALIDATED_CODEX_MIN,
    WAKE_LABEL,
    codex_version,
    daemon_version,
    launchd_loaded,
    pid_is_running,
    probe_handshake,
    version_is_validated,
)
from _rtlib import load_project_registry, projects_registry_path


def render_version(version) -> str:
    return ".".join(str(part) for part in version) if version else "unknown"


class Report:
    def __init__(self):
        self.failed = False

    def item(self, level: str, name: str, detail: str, fix: str = "none") -> None:
        print(f"{level} {name}: {detail}")
        print(f"  fix: {fix}")
        if level == "FAIL":
            self.failed = True


def socket_check(path: Path) -> tuple[bool, str]:
    try:
        info = path.lstat()
    except OSError as error:
        return False, str(error)
    if stat.S_ISLNK(info.st_mode):
        return False, "path is a symlink"
    if not stat.S_ISSOCK(info.st_mode):
        return False, "path is not a Unix socket"
    if info.st_uid != os.getuid():
        return False, f"owner uid {info.st_uid} != {os.getuid()}"
    mode = stat.S_IMODE(info.st_mode)
    if mode & 0o077:
        return False, f"unsafe mode {mode:04o}; expected no group/other access"
    return True, f"Unix socket owner={info.st_uid} mode={mode:04o}"


def daemon_fix(socket_path: Path) -> str:
    if socket_path != DEFAULT_SOCKET:
        return f"~/.roundtable/bin/rt-doctor --socket {DEFAULT_SOCKET}"
    return "~/.roundtable/bin/rt-codex-daemon ensure"


def socket_fix(socket_path: Path, detail: str) -> str:
    if detail.startswith("unsafe mode"):
        return f"chmod 600 {socket_path}"
    if detail.startswith("owner uid"):
        return f"chown $(id -u) {socket_path}"
    if socket_path != DEFAULT_SOCKET:
        return f"~/.roundtable/bin/rt-doctor --socket {DEFAULT_SOCKET}"
    if "No such file" in detail:
        return "~/.roundtable/bin/rt-codex-daemon ensure"
    return f"inspect and replace unsafe socket path {socket_path}, then run rt-codex-daemon ensure"


def parse_timestamp(value: str | None) -> datetime | None:
    if not value:
        return None
    try:
        return datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError:
        return None


def bridge_check(runtime_dir: Path, max_age: float) -> tuple[bool, str]:
    pid_path = runtime_dir / "rt-codex-wake.pid"
    alive, detail = pid_is_running(pid_path, "rt-codex-wake")
    if not alive:
        return False, detail
    heartbeat_path = runtime_dir / "rt-codex-wake-heartbeat.json"
    try:
        heartbeat = json.loads(heartbeat_path.read_text())
        if not isinstance(heartbeat, dict):
            raise ValueError("heartbeat is not a JSON object")
    except (OSError, UnicodeError, ValueError) as error:
        return False, f"invalid heartbeat: {error}"
    try:
        pid = int(pid_path.read_text().strip())
    except (OSError, ValueError):
        return False, "invalid bridge pid"
    if heartbeat.get("pid") != pid:
        return False, f"heartbeat pid {heartbeat.get('pid')} != live pid {pid}"
    timestamp = parse_timestamp(heartbeat.get("heartbeatAt"))
    if timestamp is None:
        return False, "heartbeat timestamp is missing or invalid"
    age = (datetime.now(timezone.utc) - timestamp).total_seconds()
    if age > max_age:
        return False, f"heartbeat is stale ({age:.1f}s > {max_age:.1f}s)"
    return True, f"{detail}, heartbeat age={age:.1f}s"


def process_cwd(pid: int) -> Path | None:
    proc_link = Path("/proc") / str(pid) / "cwd"
    try:
        if proc_link.exists():
            return proc_link.resolve()
    except OSError:
        pass
    try:
        proc = subprocess.run(
            ["lsof", "-a", "-p", str(pid), "-d", "cwd", "-Fn"],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            check=False,
        )
    except OSError:
        return None
    if proc.returncode != 0:
        return None
    for line in proc.stdout.splitlines():
        if line.startswith("n/"):
            try:
                return Path(line[1:]).resolve()
            except OSError:
                return None
    return None


def project_at_or_above(path: Path) -> Path | None:
    for candidate in (path, *path.parents):
        if (candidate / ".roundtable" / "agents.yaml").is_file():
            return candidate
    return None


def pid_alive(pid: int) -> bool:
    try:
        os.kill(pid, 0)
        return True
    except (OSError, ValueError):
        return False


def tripwire_process(pid: int, agent: str) -> tuple[bool, str]:
    try:
        proc = subprocess.run(
            ["ps", "-p", str(pid), "-o", "command="],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            check=False,
        )
    except OSError as error:
        return False, str(error)
    command = proc.stdout.strip()
    expected = f"rt-wait-inbox {agent}"
    return proc.returncode == 0 and expected in command, command or "process unavailable"


def project_health_checks(
    report: Report,
    registry_path: Path,
    state_file: Path,
    socket_path: Path,
    rpc_ok: bool,
) -> None:
    entries, warnings = load_project_registry(registry_path)
    for warning in warnings:
        report.item(
            "WARN",
            "registry",
            warning,
            f"inspect {registry_path}; use rt-projects rm <stale-root> when applicable",
        )
    if not entries:
        report.item(
            "WARN",
            "registry",
            f"no valid projects in {registry_path}",
            "rt-projects add <project-root>",
        )
    for entry in entries:
        report.item(
            "OK",
            "registry",
            f"{entry['root']} registered_at={entry.get('registered_at') or 'unknown'}",
        )

    registered = {str(entry["root"]): entry["root"] for entry in entries}
    saw_tripwire = False
    for project in registered.values():
        inbox = project / ".roundtable" / "inbox"
        for marker in sorted(inbox.glob("*/.armed-*")):
            try:
                pid = int(marker.name.rsplit("-", 1)[1])
            except (IndexError, ValueError):
                report.item("WARN", "tripwire-anchor", f"invalid marker {marker}")
                continue
            if not pid_alive(pid):
                continue
            agent = marker.parent.name
            is_tripwire, command = tripwire_process(pid, agent)
            if not is_tripwire:
                report.item(
                    "WARN",
                    "tripwire-anchor",
                    f"stale or reused marker {marker}: pid={pid} command={command!r}",
                    f"remove stale marker {marker}",
                )
                continue
            saw_tripwire = True
            cwd = process_cwd(pid)
            if cwd is None:
                report.item(
                    "WARN",
                    "tripwire-anchor",
                    f"pid={pid} project={project} cwd unavailable",
                    f"inspect pid {pid}",
                )
                continue
            anchored = project_at_or_above(cwd)
            if anchored == project:
                report.item(
                    "OK",
                    "tripwire-anchor",
                    f"pid={pid} cwd={cwd} project={project}",
                )
            else:
                report.item(
                    "FAIL",
                    "tripwire-anchor",
                    f"pid={pid} cwd={cwd} resolves_to={anchored} expected={project}",
                    f"restart the owning harness from {project}",
                )
    if entries and not saw_tripwire:
        report.item("OK", "tripwire-anchor", "no active tripwire markers")

    try:
        state = json.loads(state_file.read_text())
        if not isinstance(state, dict) or state.get("schema") != "roundtable.codex-wake.v1":
            raise ValueError("invalid or missing schema")
        bindings = state.get("bindings") if isinstance(state, dict) else None
        projects = state.get("projects") if isinstance(state, dict) else None
        if not isinstance(bindings, dict):
            raise ValueError("bindings is not a mapping")
        if not isinstance(projects, dict) or not all(
            isinstance(value, dict) for value in projects.values()
        ):
            raise ValueError("projects is not a mapping of states")
    except FileNotFoundError:
        bindings = {}
        projects = {}
    except (OSError, UnicodeError, json.JSONDecodeError, ValueError) as error:
        report.item(
            "FAIL",
            "codex-anchor",
            f"invalid wake state {state_file}: {error}",
            f"inspect or move aside {state_file}, then re-bind active Codex projects",
        )
        return

    for project, project_state in sorted(projects.items()):
        if project_state.get("phase") != "NEEDS_HUMAN":
            continue
        needs_human = project_state.get("needsHuman")
        reason = (
            needs_human.get("reason")
            if isinstance(needs_human, dict)
            else project_state.get("lastError")
        )
        thread_id = (
            needs_human.get("threadId") if isinstance(needs_human, dict) else None
        )
        source = (
            needs_human.get("source") if isinstance(needs_human, dict) else None
        )
        if source == "interrupted_breaker":
            recovery = (
                "attach the target Codex, inspect and resolve the repeated wake "
                f"interruption, then run rt-codex-wake bind {project}"
            )
        else:
            recovery = (
                "attach the target Codex, resolve its trust/approval/input gate, "
                f"then run rt-codex-wake bind {project}"
            )
        report.item(
            "WARN",
            "codex-wake",
            f"project={project} thread={thread_id or 'unknown'} needs human: "
            f"{reason or 'manual recovery required'}",
            recovery,
        )

    if not bindings:
        report.item("OK", "codex-anchor", "no stored Codex bindings")
        return

    client = None
    try:
        for value, binding in sorted(bindings.items()):
            try:
                project = str(Path(value).expanduser().resolve())
            except OSError:
                project = value
            registered_binding = project in registered
            if not registered_binding:
                report.item(
                    "WARN",
                    "codex-anchor",
                    f"stale binding project={project}",
                    f"rt-codex-wake unbind {project}",
                )
            if not isinstance(binding, dict):
                report.item(
                    "FAIL",
                    "codex-anchor",
                    f"binding for {project} is not a mapping",
                    f"rt-codex-wake unbind {project}",
                )
                continue
            if binding.get("agent") != "codex" or binding.get("project") != project:
                report.item(
                    "FAIL",
                    "codex-anchor",
                    f"binding identity mismatch for {project}",
                    f"rt-codex-wake unbind {project}",
                )
                continue
            thread_id = binding.get("threadId")
            if not thread_id:
                report.item(
                    "FAIL",
                    "codex-anchor",
                    f"binding for {project} has no threadId",
                    f"rt-codex-wake unbind {project}",
                )
                continue
            if not rpc_ok:
                report.item(
                    "WARN",
                    "codex-anchor",
                    f"thread={thread_id} cwd unchecked because RPC is unavailable",
                    daemon_fix(socket_path),
                )
                continue
            if client is None:
                try:
                    client = AppServerClient(socket_path)
                except Exception as error:
                    report.item(
                        "FAIL",
                        "codex-anchor",
                        f"app-server connection failed: {error}",
                        daemon_fix(socket_path),
                    )
                    break
            try:
                result = client.request(
                    "thread/read", {"threadId": thread_id, "includeTurns": False}
                )
            except Exception as error:
                report.item(
                    "FAIL",
                    "codex-anchor",
                    f"thread={thread_id} read failed: {error}",
                    f"rt-codex-wake unbind {project}",
                )
                continue
            thread = result.get("thread") or {}
            try:
                cwd = Path(thread["cwd"]).expanduser().resolve()
            except (KeyError, TypeError, OSError) as error:
                report.item(
                    "FAIL",
                    "codex-anchor",
                    f"thread={thread_id} has invalid cwd: {error}",
                    f"rt-codex-wake unbind {project}",
                )
                continue
            if str(cwd) == project:
                report.item(
                    "OK",
                    "codex-anchor",
                    f"thread={thread_id} cwd={cwd}",
                )
            else:
                report.item(
                    "FAIL",
                    "codex-anchor",
                    f"thread={thread_id} cwd={cwd} expected={project}",
                    f"rt-codex-wake unbind {project}",
                )
    finally:
        if client is not None:
            try:
                client.close()
            except OSError:
                pass


def main() -> int:
    parser = argparse.ArgumentParser(prog="rt-doctor")
    parser.add_argument("--socket", type=Path, default=DEFAULT_SOCKET)
    parser.add_argument("--runtime-dir", type=Path, default=RUNTIME_DIR)
    parser.add_argument("--bridge-max-age", type=float, default=15.0)
    parser.add_argument("--registry", type=Path, default=projects_registry_path())
    parser.add_argument("--state-file", type=Path)
    args = parser.parse_args()
    report = Report()

    cli_version, cli_output = codex_version()
    daemon, daemon_output = daemon_version(args.socket)
    daemon_socket_matches = bool(
        daemon
        and Path(daemon.get("socketPath") or "").expanduser() == args.socket.expanduser()
    )
    if daemon and daemon.get("status") == "running" and daemon_socket_matches:
        report.item(
            "OK",
            "daemon",
            f"running app-server={daemon.get('appServerVersion')} socket={daemon.get('socketPath')}",
        )
    else:
        if daemon and daemon.get("status") == "running" and not daemon_socket_matches:
            daemon_output = (
                f"reported socket {daemon.get('socketPath')} != requested {args.socket}"
            )
        report.item(
            "FAIL",
            "daemon",
            daemon_output or "daemon is not running",
            daemon_fix(args.socket),
        )

    socket_ok, socket_detail = socket_check(args.socket)
    report.item(
        "OK" if socket_ok else "FAIL",
        "socket",
        socket_detail,
        "none"
        if socket_ok
        else socket_fix(args.socket, socket_detail),
    )

    rpc_ok, rpc_detail = probe_handshake(args.socket)
    report.item(
        "OK" if rpc_ok else "FAIL",
        "rpc",
        rpc_detail,
        "none"
        if rpc_ok
        else daemon_fix(args.socket),
    )

    version_supported = False
    if cli_version is None:
        report.item(
            "FAIL",
            "version",
            f"could not parse CLI version: {cli_output}",
            "reinstall Codex CLI 0.144.3",
        )
    else:
        app_server_version = (daemon or {}).get("appServerVersion")
        if app_server_version and app_server_version != render_version(cli_version):
            report.item(
                "FAIL",
                "version",
                f"CLI {render_version(cli_version)} != app-server {app_server_version}",
                "~/.roundtable/bin/rt-codex-daemon install --reload",
            )
        elif version_is_validated(cli_version):
            version_supported = True
            report.item(
                "OK",
                "version",
                f"{render_version(cli_version)} in validated range "
                f"[{render_version(VALIDATED_CODEX_MIN)}, {render_version(VALIDATED_CODEX_MAX)}]",
            )
        else:
            report.item(
                "WARN",
                "version",
                f"{render_version(cli_version)} is outside validated range; "
                "bridge wake disabled, use legacy nudge",
                "revalidate this Codex version or install 0.144.3",
            )

    bridge_ok, bridge_detail = bridge_check(args.runtime_dir, args.bridge_max_age)
    if bridge_ok:
        bridge_level = "OK"
        bridge_fix = "none"
    elif not version_supported:
        bridge_level = "WARN"
        bridge_fix = "use legacy keyboard nudge until this Codex version is revalidated"
    elif launchd_loaded(WAKE_LABEL):
        bridge_level = "FAIL"
        bridge_fix = "launchctl kickstart -k gui/$(id -u)/com.roundtable.codex-wake"
    else:
        bridge_level = "FAIL"
        bridge_fix = "~/.roundtable/bin/rt-codex-wake install"
    report.item(
        bridge_level,
        "bridge",
        bridge_detail,
        bridge_fix,
    )
    state_file = args.state_file or args.runtime_dir / "rt-codex-wake-state.json"
    project_health_checks(
        report, args.registry, state_file, args.socket, rpc_ok
    )
    return 1 if report.failed else 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except Exception as error:
        print(f"FAIL doctor: {error}")
        print("  fix: inspect ~/.roundtable/.runtime/rt-codex-wake.log.jsonl")
        raise SystemExit(2)
