#!/usr/bin/env python3
import json
import os
import select
import shutil
import subprocess
import sys
import tempfile
import time
from datetime import datetime, timezone
from pathlib import Path

from _rtlib import find_project_root

TOOL_DIR = Path(__file__).resolve().parent


ROOT = find_project_root("rt-watch")
STATE_DIR = ROOT / ".roundtable"
RUNTIME = STATE_DIR / "runtime.json"
MSG_DIR = STATE_DIR / "messages"
LOCK_DIR = STATE_DIR / "locks"
LEDGER_LOCK = LOCK_DIR / "ledger.lock"
EVENTS_CURSOR = STATE_DIR / "events.cursor"
HEARTBEAT = STATE_DIR / "rt-watch.heartbeat"
LIFECYCLE_ORDINAL = {"pending": 0, "injected": 1, "submitted": 2, "accepted": 3, "acked": 4}
def _load_agent_names():
    """Load agent names from agents.yaml at startup, falling back to defaults."""
    try:
        import yaml as _yaml
        from _rtlib import find_project_root
        try:
            root = find_project_root("rt-watch")
        except SystemExit:
            return ("claude", "codex", "hermes")
        if root:
            with (root / ".roundtable" / "agents.yaml").open() as fh:
                doc = _yaml.safe_load(fh) or {}
                names = tuple((doc.get("agents") or {}).keys())
                return names if names else ("claude", "codex", "hermes")
    except Exception:
        pass
    return ("claude", "codex", "hermes")

AGENTS = _load_agent_names()
REFRESH_TIMEOUT_SECONDS = 10.0
STREAM_STALE_SECONDS = 120.0
HEARTBEAT_SECONDS = 2.0


def utc_now():
    return datetime.now(timezone.utc).isoformat(timespec="milliseconds").replace("+00:00", "Z")


def log(message):
    print(f"{utc_now()} {message}", file=sys.stderr, flush=True)


def read_events_cursor():
    try:
        value = EVENTS_CURSOR.read_text().strip()
    except FileNotFoundError:
        return None
    if not value:
        return None
    try:
        return int(value)
    except ValueError:
        log(f"ignoring invalid events cursor: {value!r}")
        return None


def write_events_cursor(seq):
    if seq is None:
        return
    try:
        seq = int(seq)
    except (TypeError, ValueError):
        return
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    fd, tmp_name = tempfile.mkstemp(prefix="events.cursor.tmp.", dir=STATE_DIR)
    with os.fdopen(fd, "w") as tmp:
        tmp.write(f"{seq}\n")
    shutil.move(tmp_name, EVENTS_CURSOR)


def update_cursor_from_ack(frame, requested_after):
    resume = frame.get("resume") or {}
    latest = resume.get("latest_seq")
    replay_count = resume.get("replay_count") or 0
    if resume.get("gap"):
        write_events_cursor(latest)
        log(
            "cmux events cursor reset after gap "
            f"requested_after={resume.get('requested_after_seq')} latest_seq={latest} reason={resume.get('gap_reason')}"
        )
    elif requested_after is None and replay_count == 0:
        write_events_cursor(latest)


def touch_heartbeat():
    HEARTBEAT.write_text(f"{utc_now()} pid={os.getpid()}\n")


def acquire_lock(path, timeout=10.0):
    deadline = time.time() + timeout
    while True:
        try:
            path.mkdir(parents=True)
            return
        except FileExistsError:
            if time.time() >= deadline:
                raise RuntimeError(f"timed out waiting for lock {path}")
            time.sleep(0.05)


def release_lock(path):
    shutil.rmtree(path, ignore_errors=True)


def next_event_id(ledger, msg_id, lifecycle):
    count = 0
    if ledger.exists():
        with ledger.open() as fh:
            for line in fh:
                try:
                    record = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if record.get("msg_id") == msg_id and record.get("lifecycle") == lifecycle:
                    count += 1
    return f"{msg_id}:{lifecycle}:{count + 1}"


def append_ledger(sender, record):
    ledger = MSG_DIR / f"{sender}.jsonl"
    acquire_lock(LEDGER_LOCK)
    try:
        record = dict(record)
        record["event_id"] = next_event_id(ledger, record["msg_id"], record["lifecycle"])
        with ledger.open("a") as fh:
            fh.write(json.dumps(record, ensure_ascii=False, separators=(",", ":")) + "\n")
    finally:
        release_lock(LEDGER_LOCK)


def iter_ledgers():
    for path in sorted(MSG_DIR.glob("*.jsonl")):
        if path.name.count("-") and path.stem.rsplit("-", 1)[-1].isdigit():
            continue
        yield path


def read_records():
    records = []
    for path in iter_ledgers():
        with path.open() as fh:
            for line in fh:
                try:
                    record = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if record.get("msg_id") and record.get("lifecycle") in LIFECYCLE_ORDINAL:
                    records.append(record)
    return records


def current_records(records):
    current = {}
    for record in records:
        msg_id = record.get("msg_id")
        rank = LIFECYCLE_ORDINAL.get(record.get("lifecycle"), -1)
        old = current.get(msg_id)
        old_rank = LIFECYCLE_ORDINAL.get((old or {}).get("lifecycle"), -1)
        if old is None or rank > old_rank or (rank == old_rank and record.get("ts", "") > old.get("ts", "")):
            current[msg_id] = record
    return current


def has_lifecycle(records, msg_id, lifecycle):
    return any(record.get("msg_id") == msg_id and record.get("lifecycle") == lifecycle for record in records)


def find_msg(records, msg_id):
    matches = [record for record in records if record.get("msg_id") == msg_id]
    if not matches:
        return None
    return current_records(matches).get(msg_id)


def transition_record(base, lifecycle, source, correlation):
    record = dict(base)
    record["event_id"] = ""
    record["ts"] = utc_now()
    record["lifecycle"] = lifecycle
    record["source"] = source
    merged = dict(record.get("correlation") or {})
    merged.update(correlation)
    record["correlation"] = merged
    return record


def frame_agent(frame):
    payload = frame.get("payload") or {}
    values = [
        frame.get("source"),
        frame.get("source_id"),
        payload.get("_source"),
        payload.get("source"),
        payload.get("agent"),
        payload.get("harness"),
    ]
    text = " ".join(str(value).lower() for value in values if value)
    for agent in AGENTS:
        if agent in text:
            return agent
    return None


def hook_name(frame):
    payload = frame.get("payload") or {}
    if payload.get("hook_event_name"):
        return payload.get("hook_event_name")
    name = frame.get("name") or ""
    return name.split(".")[-1]


def payload_text(frame):
    payload = frame.get("payload") or {}
    return json.dumps(payload, ensure_ascii=False).lower()


def atomic_write_runtime(runtime):
    fd, tmp_name = tempfile.mkstemp(prefix="runtime.json.tmp.", dir=STATE_DIR)
    with os.fdopen(fd, "w") as tmp:
        json.dump(runtime, tmp, indent=2, ensure_ascii=False)
        tmp.write("\n")
    shutil.move(tmp_name, RUNTIME)


def update_status(agent, status, frame):
    if not agent:
        return
    acquire_lock(LEDGER_LOCK)
    try:
        try:
            runtime = json.loads(RUNTIME.read_text())
        except (FileNotFoundError, json.JSONDecodeError):
            return
        agents = runtime.setdefault("agents", {})
        current = agents.setdefault(agent, {})
        current["status"] = status
        current["status_source"] = "rt-watch"
        current["status_updated_at"] = utc_now()
        current["last_event_seq"] = frame.get("seq")
        current["last_event_name"] = frame.get("name")
        runtime["updated_at"] = utc_now()
        atomic_write_runtime(runtime)
    finally:
        release_lock(LEDGER_LOCK)


def status_from_frame(frame):
    name = frame.get("name") or ""
    hook = hook_name(frame)
    payload = frame.get("payload") or {}
    phase = payload.get("phase")
    result = payload.get("result") or {}

    if hook == "SessionStart":
        return "alive"
    if hook == "UserPromptSubmit":
        return "busy"
    if hook == "PreToolUse":
        return "in_tool"
    if hook == "PostToolUse":
        return "busy"
    if hook == "PermissionRequest" and phase == "received":
        return "waiting_permission"
    if hook == "PermissionRequest" and result.get("status") == "resolved":
        return "busy"
    if hook == "PermissionRequest" and result.get("status") == "timed_out":
        return "blocked_or_stale"
    if hook in {"Stop", "SessionEnd"} and (phase in (None, "completed") or result.get("status") in (None, "acknowledged")):
        return "idle"
    if name == "sidebar.metadata.updated":
        text = payload_text(frame)
        if "idle" in text:
            return "idle"
        if "running" in text:
            return "busy"
    return None


def resolve_surface_agent(surface_ref):
    try:
        runtime = json.loads(RUNTIME.read_text())
    except (FileNotFoundError, json.JSONDecodeError):
        return None
    for agent, data in (runtime.get("agents") or {}).items():
        if data.get("surface_ref") == surface_ref:
            return agent
    return None


def event_surface(frame):
    payload = frame.get("payload") or {}
    params = payload.get("params") or {}
    result = payload.get("result") or {}
    return (
        frame.get("surface_ref")
        or payload.get("surface_ref")
        or params.get("surface_ref")
        or result.get("surface_ref")
        or params.get("surface_id")
        or frame.get("surface_id")
        or payload.get("surface_id")
        or result.get("surface_id")
    )


def run_refresh():
    try:
        proc = subprocess.run(
            [str(TOOL_DIR / "rt-refresh")],
            text=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.PIPE,
            timeout=REFRESH_TIMEOUT_SECONDS,
            check=False,
        )
        if proc.returncode != 0:
            detail = (proc.stderr or "").strip().splitlines()
            suffix = f": {detail[-1]}" if detail else ""
            log(f"rt-refresh exited {proc.returncode}{suffix}")
    except subprocess.TimeoutExpired:
        log(f"rt-refresh timed out after {REFRESH_TIMEOUT_SECONDS:.0f}s")


def handle_accepted(frame):
    target = frame_agent(frame)
    if not target or hook_name(frame) != "UserPromptSubmit":
        return
    records = read_records()
    current = current_records(records)
    candidates = []
    occurred_at = frame.get("occurred_at") or utc_now()
    for record in current.values():
        if record.get("to") != target:
            continue
        if record.get("lifecycle") != "submitted":
            continue
        if has_lifecycle(records, record["msg_id"], "accepted") or has_lifecycle(records, record["msg_id"], "acked"):
            continue
        if record.get("ts", "") > occurred_at:
            continue
        candidates.append(record)
    if not candidates:
        return
    selected = max(candidates, key=lambda item: item.get("ts", ""))
    accepted = transition_record(
        selected,
        "accepted",
        "rt-watch",
        {"accepted_seq": frame.get("seq"), "accepted_confidence": "serialized_latest_submitted"},
    )
    append_ledger(selected["from"], accepted)


def handle_ack_record(record):
    refs = record.get("refs") or []
    if record.get("kind") != "sync-ack" or not refs:
        return
    records = read_records()
    for ref in refs:
        original = find_msg(records, ref)
        if not original:
            continue
        if original.get("kind") == "sync-ack":
            continue
        if has_lifecycle(records, ref, "acked"):
            continue
        acked = transition_record(
            original,
            "acked",
            "rt-watch",
            {"ack_source_msg_id": record.get("msg_id")},
        )
        append_ledger(original["from"], acked)
        records.append(acked)


def poll_ledgers(offsets):
    for path in iter_ledgers():
        key = str(path)
        offset = offsets.get(key, 0)
        try:
            size = path.stat().st_size
        except FileNotFoundError:
            continue
        if size < offset:
            offset = 0
        with path.open() as fh:
            fh.seek(offset)
            for line in fh:
                try:
                    record = json.loads(line)
                except json.JSONDecodeError:
                    continue
                handle_ack_record(record)
            offsets[key] = fh.tell()


def handle_frame(frame):
    if frame.get("type") in {"ack", "heartbeat"}:
        return
    name = frame.get("name") or ""
    if name in {"surface.created", "surface.selected", "surface.focused", "workspace.selected"}:
        run_refresh()
    if name == "surface.destroyed":
        surface = event_surface(frame)
        agent = resolve_surface_agent(surface)
        if agent:
            update_status(agent, "blocked_or_stale", frame)
        run_refresh()

    agent = frame_agent(frame)
    status = status_from_frame(frame)
    if agent and status:
        update_status(agent, status, frame)
    handle_accepted(frame)


def start_events():
    after_seq = read_events_cursor()
    cmd = ["cmux", "events", "--reconnect"]
    if after_seq is not None:
        cmd.extend(["--after", str(after_seq)])
    log(f"starting cmux events after_seq={after_seq} cursor_file={EVENTS_CURSOR}")
    proc = subprocess.Popen(
        cmd,
        text=True,
        bufsize=1,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    return proc, after_seq


def stop_events(proc):
    try:
        proc.terminate()
        proc.wait(timeout=1.0)
    except Exception:
        try:
            proc.kill()
        except Exception:
            pass


def restart_events(proc, reason):
    log(f"restarting cmux events: {reason}")
    stop_events(proc)
    time.sleep(0.2)
    return start_events()


def process_events_line(line, requested_after):
    try:
        frame = json.loads(line)
    except json.JSONDecodeError:
        log("ignored non-json cmux events line")
        return False
    if frame.get("type") == "ack":
        update_cursor_from_ack(frame, requested_after)
        return True
    handle_frame(frame)
    if frame.get("type") not in {"ack", "heartbeat"}:
        write_events_cursor(frame.get("seq"))
    return True


def drain_streams(proc, requested_after):
    saw_frame = False
    streams = [(proc.stdout, "stdout"), (proc.stderr, "stderr")]
    while True:
        readable = []
        for stream, name in streams:
            if stream is None:
                continue
            ready, _, _ = select.select([stream], [], [], 0)
            if ready:
                readable.append((stream, name))
        if not readable:
            return saw_frame
        for stream, name in readable:
            line = stream.readline()
            if not line:
                return saw_frame
            if name == "stderr":
                log(f"cmux events stderr: {line.strip()}")
                continue
            saw_frame = process_events_line(line, requested_after) or saw_frame


def main():
    STATE_DIR.mkdir(exist_ok=True)
    MSG_DIR.mkdir(exist_ok=True)
    LOCK_DIR.mkdir(exist_ok=True)
    if not RUNTIME.exists():
        run_refresh()

    offsets = {}
    last_refresh = 0.0
    last_poll = 0.0
    last_heartbeat = 0.0
    last_stream_frame = time.time()
    proc, requested_after = start_events()
    try:
        while True:
            now = time.time()
            if now - last_heartbeat >= HEARTBEAT_SECONDS:
                touch_heartbeat()
                last_heartbeat = now
            if now - last_poll >= 1.0:
                poll_ledgers(offsets)
                last_poll = now
            if now - last_refresh >= 60.0:
                run_refresh()
                last_refresh = now

            if drain_streams(proc, requested_after):
                last_stream_frame = time.time()

            if proc.poll() is not None:
                if drain_streams(proc, requested_after):
                    last_stream_frame = time.time()
                proc, requested_after = restart_events(proc, f"process exited rc={proc.returncode}")
                last_stream_frame = time.time()
                continue
            if now - last_stream_frame >= STREAM_STALE_SECONDS:
                proc, requested_after = restart_events(proc, f"no frames for {STREAM_STALE_SECONDS:.0f}s")
                last_stream_frame = time.time()
                continue

            readable, _, _ = select.select([proc.stdout, proc.stderr], [], [], 0.2)
            if not readable:
                continue
            for stream in readable:
                line = stream.readline()
                if not line:
                    if proc.poll() is not None:
                        break
                    continue
                if stream is proc.stderr:
                    log(f"cmux events stderr: {line.strip()}")
                    continue
                if process_events_line(line, requested_after):
                    last_stream_frame = time.time()
    except KeyboardInterrupt:
        return
    except Exception as exc:
        log(f"fatal error: {type(exc).__name__}: {exc}")
        raise
    finally:
        stop_events(proc)


if __name__ == "__main__":
    main()
