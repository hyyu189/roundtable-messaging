#!/usr/bin/env python3
import os
import re
import subprocess
import sys
from collections import defaultdict
from pathlib import Path

from _rtlib import find_project_root

TOOL_DIR = Path(__file__).resolve().parent
# Agent names may be multi-instance ids (claude#1, codex-build), so the from/to
# fields can contain digits, '#', '_' and '-'. Anchor on the timestamp prefix,
# the literal '-to-' separator, and a hyphen-free random suffix.
MSG_ID_RE = re.compile(r"^\d{8}T\d{6}Z-([a-z0-9#_-]+)-to-([a-z0-9#_-]+)-[^-]+$")


ROOT = find_project_root("rt-ack")


def usage():
    print("usage: rt-ack <ref_csv> [body]", file=sys.stderr)
    raise SystemExit(2)


def parse_ref(ref):
    match = MSG_ID_RE.match(ref)
    if not match:
        raise SystemExit(f"rt-ack: cannot parse msg_id: {ref}")
    return match.groups()


def main():
    if len(sys.argv) < 2:
        usage()
    refs = [ref.strip() for ref in sys.argv[1].split(",") if ref.strip()]
    if not refs:
        usage()
    body = " ".join(sys.argv[2:]) if len(sys.argv) > 2 else ""

    parsed_refs = []
    for ref in refs:
        original_from, original_to = parse_ref(ref)
        parsed_refs.append((ref, original_from, original_to))

    recipients = {original_to for _ref, _original_from, original_to in parsed_refs}
    if len(recipients) != 1:
        raise SystemExit(
            "rt-ack: refs target multiple recipients: "
            + ", ".join(sorted(recipients))
            + "; acknowledge one recipient at a time"
        )
    inferred_sender = next(iter(recipients))
    explicit_sender = os.environ.get("RT_FROM", "").lower()
    if explicit_sender and explicit_sender != inferred_sender:
        raise SystemExit(
            f"rt-ack: RT_FROM={explicit_sender} does not match message recipient "
            f"{inferred_sender}"
        )

    groups = defaultdict(list)
    for ref, original_from, _original_to in parsed_refs:
        groups[original_from].append(ref)

    outputs = []
    for target, group_refs in groups.items():
        csv = ",".join(group_refs)
        visible_body = f"refs={csv}"
        if body:
            visible_body = f"{visible_body} {body}"
        env = os.environ.copy()
        env["RT_ACK_MODE"] = "1"
        env["RT_ACK_REFS"] = csv
        env["RT_ACK_BODY"] = body
        env["RT_FROM"] = explicit_sender or inferred_sender
        # Every ref has already agreed on the message recipient and any
        # explicit RT_FROM has been checked against it. The normal maildir path
        # consumes this validated harness identity without a terminal adapter.
        command = [
            str(TOOL_DIR / "rt-say"),
            target,
            "sync-ack",
            visible_body,
        ]
        try:
            proc = subprocess.run(
                command,
                text=True,
                check=False,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                env=env,
            )
        except OSError as error:
            raise SystemExit(f"rt-ack: failed to run rt-say: {error}") from None
        if proc.returncode != 0:
            detail = proc.stderr.strip() or f"rt-say exited {proc.returncode}"
            print(detail, file=sys.stderr)
            raise SystemExit(proc.returncode)
        if proc.stderr.strip():
            print(proc.stderr.strip(), file=sys.stderr)
        outputs.append(proc.stdout.strip())

    print("\n".join(output for output in outputs if output))


if __name__ == "__main__":
    main()
