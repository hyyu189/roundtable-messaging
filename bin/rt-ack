#!/usr/bin/env python3
import os
import re
import stat
import subprocess
import sys
from collections import defaultdict
from pathlib import Path

from _rtlib import find_project_root, require_fenced_seat

TOOL_DIR = Path(__file__).resolve().parent
# Agent names may be multi-instance ids (claude#1, codex-build), so the from/to
# fields can contain digits, '#', '_' and '-'. Anchor on the timestamp prefix,
# the literal '-to-' separator, and a hyphen-free random suffix.
MSG_ID_RE = re.compile(r"^\d{8}T\d{6}Z-([a-z0-9#_-]+)-to-([a-z0-9#_-]+)-[^-]+$")


ROOT = find_project_root("rt-ack")


def usage():
    print("usage: rt-ack [--fenced] <ref_csv> [body]", file=sys.stderr)
    raise SystemExit(2)


def parse_ref(ref):
    match = MSG_ID_RE.match(ref)
    if (
        not match
        or Path(ref).name != ref
        or "/" in ref
        or "\x00" in ref
    ):
        raise SystemExit(f"rt-ack: cannot parse msg_id: {ref}")
    return match.groups()


def fsync_directory(path):
    descriptor = os.open(path, os.O_RDONLY)
    try:
        os.fsync(descriptor)
    finally:
        os.close(descriptor)


def lstat_or_none(path):
    try:
        return path.lstat()
    except FileNotFoundError:
        return None


def archive_inbound(ref, recipient):
    """Move one exact inbound ref from new/ to cur/ without clobbering.

    A hard-link followed by unlink gives us a no-clobber publication and a
    recoverable intermediate state. If a prior attempt stopped between those
    operations, both names identify the same inode and this retry completes the
    unlink. Missing mail is a compatibility no-op: rt-ack historically accepted
    a valid ref after a manual drain or when only legacy ledger state remained.
    """

    mail_root = ROOT / ".roundtable" / "inbox"
    inbox = mail_root / recipient
    new_dir = inbox / "new"
    cur_dir = inbox / "cur"
    source = new_dir / f"{ref}.md"
    destination = cur_dir / f"{ref}.md"

    for directory in (mail_root, inbox, new_dir):
        if directory.is_symlink():
            raise OSError(f"maildir path is a symlink: {directory}")
        if directory.exists() and not directory.is_dir():
            raise OSError(f"maildir path is not a directory: {directory}")

    source_stat = lstat_or_none(source)
    destination_stat = lstat_or_none(destination)
    if source_stat is None:
        if destination_stat is not None and not stat.S_ISREG(destination_stat.st_mode):
            raise OSError(f"archive destination is not a regular file: {destination}")
        return
    if not stat.S_ISREG(source_stat.st_mode):
        raise OSError(f"inbound mail is not a regular file: {source}")

    cur_dir.mkdir(parents=True, exist_ok=True)
    if cur_dir.is_symlink() or not cur_dir.is_dir():
        raise OSError(f"archive directory is not a real directory: {cur_dir}")

    destination_stat = lstat_or_none(destination)
    if destination_stat is not None:
        if not stat.S_ISREG(destination_stat.st_mode):
            raise OSError(f"archive destination is not a regular file: {destination}")
        if (source_stat.st_dev, source_stat.st_ino) != (
            destination_stat.st_dev,
            destination_stat.st_ino,
        ):
            raise FileExistsError(
                f"refusing to overwrite conflicting archive: {destination}"
            )
        fsync_directory(cur_dir)
    else:
        os.link(source, destination, follow_symlinks=False)
        fsync_directory(cur_dir)

    source.unlink()
    fsync_directory(new_dir)


def main():
    args = list(sys.argv[1:])
    fenced = bool(args and args[0] == "--fenced")
    if fenced:
        args.pop(0)
    if "--fenced" in args or not args:
        usage()
    fenced_agent = require_fenced_seat(ROOT, "rt-ack") if fenced else ""
    refs = [ref.strip() for ref in args[0].split(",") if ref.strip()]
    if not refs:
        usage()
    body = " ".join(args[1:]) if len(args) > 1 else ""

    parsed_refs = []
    for ref in refs:
        original_from, original_to = parse_ref(ref)
        parsed_refs.append((ref, original_from, original_to))

    recipients = {original_to for _ref, _original_from, original_to in parsed_refs}
    if len(recipients) != 1:
        raise SystemExit(
            "rt-ack: refs target multiple recipients: "
            + ", ".join(sorted(recipients))
            + "; acknowledge one recipient at a time"
        )
    inferred_sender = next(iter(recipients))
    explicit_sender = os.environ.get("RT_FROM", "").lower()
    if fenced_agent and inferred_sender != fenced_agent:
        raise SystemExit(
            f"rt-ack: fenced seat {fenced_agent} cannot acknowledge mail for "
            f"{inferred_sender}"
        )
    if explicit_sender and explicit_sender != inferred_sender:
        raise SystemExit(
            f"rt-ack: RT_FROM={explicit_sender} does not match message recipient "
            f"{inferred_sender}"
        )

    groups = defaultdict(list)
    for ref, original_from, _original_to in parsed_refs:
        groups[original_from].append(ref)

    outputs = []
    for target, group_refs in groups.items():
        csv = ",".join(group_refs)
        visible_body = f"refs={csv}"
        if body:
            visible_body = f"{visible_body} {body}"
        env = os.environ.copy()
        env["RT_ACK_MODE"] = "1"
        env["RT_ACK_REFS"] = csv
        env["RT_ACK_BODY"] = body
        env["RT_FROM"] = explicit_sender or inferred_sender
        # Every ref has already agreed on the message recipient and any
        # explicit RT_FROM has been checked against it. The normal maildir path
        # consumes this validated harness identity without a terminal adapter.
        command = [
            str(TOOL_DIR / "rt-say"),
            target,
            "sync-ack",
            visible_body,
        ]
        try:
            proc = subprocess.run(
                command,
                text=True,
                check=False,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                env=env,
            )
        except OSError as error:
            raise SystemExit(f"rt-ack: failed to run rt-say: {error}") from None
        if proc.returncode != 0:
            detail = proc.stderr.strip() or f"rt-say exited {proc.returncode}"
            print(detail, file=sys.stderr)
            raise SystemExit(proc.returncode)
        if proc.stderr.strip():
            print(proc.stderr.strip(), file=sys.stderr)
        output = proc.stdout.strip()
        try:
            for ref in group_refs:
                archive_inbound(ref, inferred_sender)
        except OSError as error:
            for committed_output in outputs:
                if committed_output:
                    print(committed_output)
            if output:
                print(output)
            raise SystemExit(
                "rt-ack: acknowledgement delivered for "
                f"refs={csv}, but failed to archive inbound mail: {error}"
            ) from None
        outputs.append(output)

    print("\n".join(output for output in outputs if output))


if __name__ == "__main__":
    main()
