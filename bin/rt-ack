#!/usr/bin/env python3
import os
import re
import subprocess
import sys
from collections import defaultdict
from pathlib import Path

from _rtlib import find_project_root

TOOL_DIR = Path(__file__).resolve().parent
# Agent names may be multi-instance ids (claude#1, codex-build), so the from/to
# fields can contain digits, '#', '_' and '-'. Anchor on the timestamp prefix,
# the literal '-to-' separator, and a hyphen-free random suffix.
MSG_ID_RE = re.compile(r"^\d{8}T\d{6}Z-([a-z0-9#_-]+)-to-([a-z0-9#_-]+)-[^-]+$")


ROOT = find_project_root("rt-ack")


def usage():
    print("usage: bin/rt-ack <ref_csv> [body]", file=sys.stderr)
    raise SystemExit(2)


def parse_ref(ref):
    match = MSG_ID_RE.match(ref)
    if not match:
        raise SystemExit(f"rt-ack: cannot parse msg_id: {ref}")
    original_from, _original_to = match.groups()
    return original_from


def main():
    if len(sys.argv) < 2:
        usage()
    refs = [ref.strip() for ref in sys.argv[1].split(",") if ref.strip()]
    if not refs:
        usage()
    body = " ".join(sys.argv[2:]) if len(sys.argv) > 2 else ""

    groups = defaultdict(list)
    for ref in refs:
        groups[parse_ref(ref)].append(ref)

    outputs = []
    for target, group_refs in groups.items():
        csv = ",".join(group_refs)
        visible_body = f"refs={csv}"
        if body:
            visible_body = f"{visible_body} {body}"
        env = os.environ.copy()
        env["RT_ACK_MODE"] = "1"
        env["RT_ACK_REFS"] = csv
        env["RT_ACK_BODY"] = body
        proc = subprocess.run(
            [str(TOOL_DIR / "rt-say"), target, "sync-ack", visible_body],
            text=True,
            check=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            env=env,
        )
        outputs.append(proc.stdout.strip())

    print("\n".join(output for output in outputs if output))


if __name__ == "__main__":
    main()
