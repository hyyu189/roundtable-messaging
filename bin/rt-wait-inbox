#!/usr/bin/env bash
# rt-wait-inbox <agent> [max-minutes] — v2 delivery tripwire.
# Blocks until a maildir message lands in the current project's inbox for
# <agent>, or until timeout. Exits 0 either way and prints the trigger cause.
# Maintains an armed-marker (.armed-<pid>) so a Stop-hook gate can verify a
# live tripwire exists before letting the agent go idle.
# Run it as a harness-tracked background process (Claude: run_in_background;
# Hermes: terminal(background=true, notify_on_complete=true)).
set -u
agent=${1:?usage: rt-wait-inbox <agent> [max-minutes]}
max_min=${2:-30}

dir=$PWD
while [ "$dir" != "/" ] && [ ! -d "$dir/.roundtable" ]; do dir=$(dirname "$dir"); done
if [ ! -d "$dir/.roundtable" ]; then
  echo "rt-wait-inbox: no .roundtable project root at or above $PWD" >&2
  exit 2
fi

inbox="$dir/.roundtable/inbox/$agent"
mkdir -p "$inbox/new" "$inbox/cur" "$inbox/tmp"
marker="$inbox/.armed-$$"
echo "$(date -u +%Y%m%dT%H%M%SZ) pid=$$ max_min=$max_min" > "$marker"
trap 'rm -f "$marker"' EXIT HUP INT TERM

i=0
limit=$((max_min * 12))
until [ -n "$(ls "$inbox/new" 2>/dev/null)" ] || [ "$i" -ge "$limit" ]; do
  sleep 5
  i=$((i + 1))
done

if [ -n "$(ls "$inbox/new" 2>/dev/null)" ]; then
  echo "rt-wait-inbox: mail after $((i * 5))s:"
  ls "$inbox/new"
else
  echo "rt-wait-inbox: heartbeat timeout after ${max_min}m (inbox empty)"
fi
