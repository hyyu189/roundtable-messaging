#!/usr/bin/env python3
"""Wait for project mail while keeping host-local wake state fenced.

The durable maildir remains under ``<project>/.roundtable/inbox``.  Process
identity, activity, heartbeat, and adaptive-backoff state belong to the
currently claimed host-local seat in ``RT_RUNTIME_DIR``.
"""

from __future__ import annotations

import json
import os
import signal
import sys
import time
from pathlib import Path
from typing import Any

from _rtlib import is_project_root
from _rtruntime import (
    FenceRejected,
    RuntimeStateError,
    clear_wake,
    load_validated_lease,
    update_wake,
    watcher_is_live,
)


DEFAULT_MINUTES = 45
FLOOR_MINUTES = 240
BACKOFF_AFTER = 6
POLL_SECONDS = 5


class StopRequested(Exception):
    pass


def _managed_command_root() -> Path:
    configured = os.environ.get("ROUNDTABLE_INSTALL_PREFIX")
    if configured:
        prefix = Path(configured).expanduser()
        if prefix.is_absolute():
            return prefix / "bin"
    return Path(os.path.abspath(sys.argv[0])).parent


def _claude_drain_instructions(agent: str) -> str:
    command_root = _managed_command_root()
    return (
        "Roundtable mail arrived. Read and act on every pending message for "
        f"{agent!r}. Use these package-managed command paths exactly so the "
        "narrow setup permissions apply:\n"
        f"  {command_root / 'rt-inbox'} --fenced --archive-quiet-acks "
        "-f json\n"
        f"  {command_root / 'rt-ack'} --fenced <id>[,<id>...]\n"
        f"  {command_root / 'rt-say'} --fenced --no-nudge "
        "<agent> <kind> <body...>\n"
        "The Stop hook re-arms the inbox watcher automatically after this "
        "turn; do not start another watcher yourself."
    )


def _stop(_signum, _frame) -> None:
    raise StopRequested


def _project_at_or_above(start: Path) -> Path | None:
    current = start.expanduser().resolve()
    for candidate in (current, *current.parents):
        if is_project_root(candidate):
            return candidate
    return None


def _project_root() -> Path:
    configured = os.environ.get("RT_PROJECT_ROOT")
    discovered = _project_at_or_above(Path.cwd())
    if configured:
        project = Path(configured).expanduser().resolve()
        if not is_project_root(project):
            raise RuntimeStateError(
                f"RT_PROJECT_ROOT is not a Roundtable project: {project}"
            )
        if discovered is not None and discovered != project:
            raise RuntimeStateError(
                f"RT_PROJECT_ROOT {project} does not match cwd project {discovered}"
            )
        return project
    if discovered is None:
        raise RuntimeStateError(
            f"no roundtable project (.roundtable/agents.yaml) at or above {Path.cwd()}"
        )
    return discovered


def _lease_environment(agent: str) -> tuple[str, str]:
    session_id = os.environ.get("RT_SESSION_ID")
    revision = os.environ.get("RT_LEASE_REVISION")
    missing = [
        name
        for name, value in (
            ("RT_SESSION_ID", session_id),
            ("RT_LEASE_REVISION", revision),
        )
        if not value
    ]
    if missing:
        raise RuntimeStateError(
            "missing claimed-seat environment: " + ", ".join(missing)
        )
    launched_as = os.environ.get("RT_FROM")
    if launched_as and launched_as != agent:
        raise RuntimeStateError(
            f"RT_FROM={launched_as!r} does not match requested agent {agent!r}"
        )
    return session_id, revision


def _field(value: Any, name: str, default=None):
    if hasattr(value, name):
        return getattr(value, name)
    for container_name in ("record", "state", "data"):
        container = getattr(value, container_name, None)
        if isinstance(container, dict) and name in container:
            return container[name]
    if isinstance(value, dict):
        return value.get(name, default)
    return default


def _integer_field(value: Any, name: str, default: int = 0) -> int:
    raw = _field(value, name, default)
    if isinstance(raw, bool):
        return default
    try:
        parsed = int(raw)
    except (TypeError, ValueError):
        return default
    return max(0, parsed)


def _activity_stamp(value: Any):
    for name in ("activity_revision", "activity_at", "last_activity_at"):
        stamp = _field(value, name)
        if stamp is not None:
            return stamp
    return None


def _wake_mail(new_dir: Path) -> list[str]:
    try:
        names = sorted(path.name for path in new_dir.iterdir())
    except FileNotFoundError:
        return []
    return [name for name in names if not name.startswith(("ack-", "."))]


def _ack_count(new_dir: Path) -> int:
    try:
        return sum(
            1
            for path in new_dir.iterdir()
            if path.name.startswith("ack-") and not path.name.startswith(".")
        )
    except FileNotFoundError:
        return 0


def _parse_minutes(raw: str | None) -> int | None:
    if raw is None:
        return None
    try:
        value = int(raw)
    except ValueError as error:
        raise RuntimeStateError(f"max-minutes must be a non-negative integer: {raw}") from error
    if value < 0:
        raise RuntimeStateError(f"max-minutes must be a non-negative integer: {raw}")
    return value


def _pick_max(explicit: int | None, empty_beats: int) -> int:
    if explicit is not None:
        return explicit
    return FLOOR_MINUTES if empty_beats >= BACKOFF_AFTER else DEFAULT_MINUTES


def run(
    agent: str,
    explicit_minutes: int | None,
    *,
    claude_hook: bool = False,
    claude_stop_hook: bool = False,
    stop_hook_active: bool = False,
) -> int:
    project = _project_root()
    session_id, revision = _lease_environment(agent)
    # Validate before touching either the durable inbox or host-local runtime.
    lease = load_validated_lease(project, agent, session_id, revision)
    # SessionStart also fires after compaction. If the original async Claude
    # hook is still healthy, the duplicate hook must quietly stand down rather
    # than replacing it or spuriously waking Claude with a fence error.
    if claude_hook and watcher_is_live(lease):
        return 0

    inbox = project / ".roundtable" / "inbox" / agent
    new_dir = inbox / "new"
    for path in (new_dir, inbox / "cur", inbox / "tmp"):
        path.mkdir(parents=True, exist_ok=True)
    pending_at_stop = _wake_mail(new_dir)
    if (
        claude_stop_hook
        and stop_hook_active
        and tuple(pending_at_stop) == lease.last_wake_messages
        and lease.wake_attempts >= 2
    ):
        print(
            "rt-wait-inbox: the same Roundtable mail generation is still "
            "pending after one Stop-hook retry; automatic re-wake is paused "
            "to prevent a loop. "
            "The mail remains durable in new/. Resolve any /permissions or "
            "command error, then interact with this Claude session to retry.",
            file=sys.stderr,
        )
        return 0

    watcher_pid = os.getpid()
    try:
        try:
            token = update_wake(
                project,
                agent,
                session_id,
                revision,
                watcher_pid=watcher_pid,
            )
        except FenceRejected:
            if claude_hook and watcher_is_live(
                load_validated_lease(project, agent, session_id, revision)
            ):
                return 0
            raise
        empty_beats = _integer_field(token, "empty_beats")
        activity = _activity_stamp(token)
        max_minutes = _pick_max(explicit_minutes, empty_beats)
        ticks = 0
        mail = _wake_mail(new_dir)
        superseded = False

        while not mail and ticks < max_minutes * (60 // POLL_SECONDS):
            time.sleep(POLL_SECONDS)
            try:
                token = update_wake(
                    project,
                    agent,
                    session_id,
                    revision,
                    expected_watcher_pid=watcher_pid,
                )
            except FenceRejected:
                superseded = True
                break
            current_activity = _activity_stamp(token)
            if current_activity != activity:
                activity = current_activity
                ticks = 0
                empty_beats = 0
                max_minutes = _pick_max(explicit_minutes, empty_beats)
                token = update_wake(
                    project,
                    agent,
                    session_id,
                    revision,
                    empty_beats=0,
                    expected_watcher_pid=watcher_pid,
                )
            else:
                ticks += 1
            mail = _wake_mail(new_dir)

        if superseded:
            print("rt-wait-inbox: seat lease or watcher was superseded")
            return 0
        if mail:
            prior_messages = token.last_wake_messages
            attempts = (
                token.wake_attempts + 1
                if tuple(mail) == prior_messages
                else 1
            )
            token = update_wake(
                project,
                agent,
                session_id,
                revision,
                empty_beats=0,
                last_wake_messages=mail,
                wake_attempts=attempts,
                expected_watcher_pid=watcher_pid,
            )
            print(f"rt-wait-inbox: mail after {ticks * POLL_SECONDS}s:")
            print("\n".join(mail))
            if claude_hook:
                print(_claude_drain_instructions(agent), file=sys.stderr)
        else:
            empty_beats += 1
            update_wake(
                project,
                agent,
                session_id,
                revision,
                empty_beats=empty_beats,
                expected_watcher_pid=watcher_pid,
            )
            print(
                "rt-wait-inbox: heartbeat timeout after "
                f"{max_minutes}m (inbox empty; consecutive empty beats: "
                f"{empty_beats})"
            )
            if claude_hook:
                print(
                    "Roundtable inbox heartbeat completed. The Stop hook will "
                    "re-arm the watcher automatically; do not start another "
                    "watcher yourself.",
                    file=sys.stderr,
                )
        acks = _ack_count(new_dir)
        if acks:
            print(
                f"rt-wait-inbox: {acks} quiet ack file(s) pending in new/ "
                "— drain to cur/ while you're awake"
            )
        # Claude Code's asyncRewake contract wakes an idle session only when
        # the background hook exits 2. Ordinary terminal/Hermes watchers keep
        # their historical success exit so their native background-process
        # notification path remains unchanged.
        return 2 if claude_hook else 0
    except StopRequested:
        return 0
    finally:
        try:
            clear_wake(
                project,
                agent,
                session_id,
                revision,
                expected_watcher_pid=watcher_pid,
            )
        except (FenceRejected, RuntimeStateError):
            # A superseded watcher must never clear its successor's wake state.
            pass


def _claude_hook_is_managed() -> bool:
    """Return whether a global Claude hook belongs to a claimed RT session.

    The hook is installed in user-level settings and therefore fires for every
    Claude project. A normal direct Claude launch must remain a silent no-op.
    Partial lease context is deliberately treated as managed so ``run`` can
    fail closed and surface the broken launch environment.
    """

    return any(
        os.environ.get(name)
        for name in (
            "RT_PROJECT_ROOT",
            "RT_FROM",
            "RT_SESSION_ID",
            "RT_LEASE_REVISION",
        )
    )


def main(argv: list[str] | None = None) -> int:
    argv = list(sys.argv[1:] if argv is None else argv)
    claude_stop_hook = bool(argv and argv[0] == "--claude-stop-hook")
    claude_hook = bool(
        argv and argv[0] in ("--claude-hook", "--claude-stop-hook")
    )
    stop_hook_active = False
    if claude_hook:
        argv.pop(0)
        if not _claude_hook_is_managed():
            return 0
        if claude_stop_hook:
            try:
                hook_input = json.load(sys.stdin)
                if not isinstance(hook_input, dict):
                    raise ValueError("hook input must be an object")
                stop_hook_active = hook_input.get("stop_hook_active") is True
            except (OSError, ValueError, json.JSONDecodeError) as error:
                print(
                    "rt-wait-inbox: invalid Claude Stop hook input; refusing "
                    f"automatic re-wake to avoid a loop: {error}",
                    file=sys.stderr,
                )
                return 0
        if not argv:
            launched_as = os.environ.get("RT_FROM", "").strip()
            if launched_as:
                argv.append(launched_as)
    if not 1 <= len(argv) <= 2:
        print(
            "usage: rt-wait-inbox [--claude-hook|--claude-stop-hook] "
            "<agent> [max-minutes]",
            file=sys.stderr,
        )
        return 2
    try:
        explicit = _parse_minutes(argv[1] if len(argv) == 2 else None)
        return run(
            argv[0],
            explicit,
            claude_hook=claude_hook,
            claude_stop_hook=claude_stop_hook,
            stop_hook_active=stop_hook_active,
        )
    except (FenceRejected, RuntimeStateError, OSError) as error:
        print(f"rt-wait-inbox: {error}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    signal.signal(signal.SIGTERM, _stop)
    signal.signal(signal.SIGINT, _stop)
    raise SystemExit(main())
