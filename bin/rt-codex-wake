MAIL_RE = re.compile(
    r"^\[(?P<from>[A-Z0-9#_-]+)→(?P<to>[A-Z0-9#_-]+)\s+"
    r"(?P<kind>\S+)\s+id=(?P<id>[^\]]+)\]"
)
WAKE_TEXT = (
    "drain inbox at {inbox}, 按 roundtable skill Delivery v2 协议处理"
)
STATE_SCHEMA = "roundtable.codex-wake.v1"
BIND_REQUEST_SCHEMA = "roundtable.codex-bind-request.v1"
BIND_REQUESTS_DIRNAME = "codex-bind-requests"
BIND_REQUEST_MAX_BYTES = 64 * 1024
BIND_REQUEST_SOURCES = frozenset({"startup", "resume", "clear"})
BRIDGE_BUILD_FINGERPRINT = wake_bridge_build_fingerprint()
INTERRUPTED_BREAKER_LIMIT = 3
