        "item/tool/requestUserInput",
        "mcpServer/elicitation/request",
    }
)


class IdentityError(RuntimeError):
    pass


class HumanGate(RuntimeError):
    def __init__(self, source: str, reason: str):
        super().__init__(reason)
        self.source = source
        self.reason = reason


class UnsafeBindRequest(RuntimeError):
    """A queue entry cannot be inspected without following unsafe state."""


class MalformedBindRequest(RuntimeError):
    """A private regular queue entry has invalid request content."""

    def __init__(self, reason: str, identity: tuple[int, int] | None = None):
        super().__init__(reason)
        self.identity = identity


def utc_now() -> str:
    return datetime.now(timezone.utc).isoformat(timespec="milliseconds").replace(
        "+00:00", "Z"
    )


def atomic_json(path: Path, payload: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True, mode=0o700)
    tmp = path.with_name(f".{path.name}.tmp.{os.getpid()}.{time.time_ns()}")
    try:
        descriptor = os.open(tmp, os.O_WRONLY | os.O_CREAT | os.O_EXCL, 0o600)
        with os.fdopen(descriptor, "w", encoding="utf-8") as handle:
            json.dump(payload, handle, ensure_ascii=False, sort_keys=True, indent=2)
            handle.write("\n")
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(tmp, path)
    finally:
        try:
            tmp.unlink()
        except FileNotFoundError:
            pass


class StateStore:
    def __init__(self, path: Path):
        self.path = path
        self.data = {"schema": STATE_SCHEMA, "bindings": {}, "projects": {}}
        self.reload()

    def _read(self) -> dict | None:
        try:
            loaded = json.loads(self.path.read_text())
            if not isinstance(loaded, dict) or loaded.get("schema") != STATE_SCHEMA:
                return None
            bindings = loaded.get("bindings")
            projects = loaded.get("projects")
            if not isinstance(bindings, dict) or not isinstance(projects, dict):
                return None
            if not all(isinstance(value, dict) for value in bindings.values()):
                return None
            if not all(isinstance(value, dict) for value in projects.values()):
                return None
            return loaded
        except (OSError, UnicodeError, json.JSONDecodeError):
            pass
        return None

    def _lock(self, exclusive: bool):
        lock_path = self.path.with_name(f"{self.path.name}.lock")
        lock_path.parent.mkdir(parents=True, exist_ok=True, mode=0o700)
        descriptor = os.open(lock_path, os.O_RDWR | os.O_CREAT, 0o600)
        handle = os.fdopen(descriptor, "r+")
        fcntl.flock(handle.fileno(), fcntl.LOCK_EX if exclusive else fcntl.LOCK_SH)
        return handle

    def reload(self) -> None:
        with self._lock(False):
            loaded = self._read()
        if loaded is not None:
            self.data = loaded

    @property
    def bindings(self) -> dict:
        return self.data.setdefault("bindings", {})

    def project_state(self, project: Path) -> dict:
        return self.data.setdefault("projects", {}).setdefault(str(project), {})

    def save(self) -> None:
        # A target Codex may rebind while the bridge is running. Preserve the
        # newest on-disk bindings so a phase-state write cannot undo that bind.
        with self._lock(True):
            loaded = self._read()
            if loaded is not None:
                local_bindings = self.data.get("bindings") or {}
                disk_bindings = loaded.get("bindings") or {}
                disk_projects = loaded.get("projects") or {}
                projects = self.data.setdefault("projects", {})
                for project, disk_binding in disk_bindings.items():
                    # bind() resets project phase under this same lock. A
                    # running bridge must not resurrect pre-rebind state.
                    if local_bindings.get(project) != disk_binding:
                        projects[project] = dict(disk_projects.get(project) or {})
                self.data["bindings"] = disk_bindings
            atomic_json(self.path, self.data)

    @contextmanager
    def transaction(self):
        """Reload and hold the state lock across a routing-critical action."""
        with self._lock(True):
            loaded = self._read()
            if loaded is not None:
                self.data = loaded
            yield self

    def flush_transaction(self) -> None:
        """Persist while transaction() owns the exclusive state lock."""
        atomic_json(self.path, self.data)

    def bind(
        self,
        project: Path,
        thread: dict,
        lease: LeaseToken | None = None,
    ) -> None:
        thread_id = thread["id"]
        with self._lock(True):
            loaded = self._read()
            if loaded is not None:
                self.data = loaded
            for other_project, binding in self.bindings.items():
                if other_project != str(project) and binding.get("threadId") == thread_id:
                    raise IdentityError(
                        f"thread {thread_id} is already bound to {other_project}"
                    )
            binding = {
                "agent": lease.agent_id if lease is not None else "codex",
                "project": str(project),
                "threadId": thread_id,
                "sessionId": thread.get("sessionId"),
                "bindingRevision": uuid.uuid4().hex,
                "boundAt": utc_now(),
            }
            if lease is not None:
                binding.update(
                    {
                        "roundtableSessionId": lease.session_id,
                        "leaseRevision": lease.revision,
                    }
                )
            self.bindings[str(project)] = binding
            self.data.setdefault("projects", {})[str(project)] = {
                "phase": "EMPTY",
                "reboundAt": utc_now(),
            }
            atomic_json(self.path, self.data)

    def bind_if_absent(
        self,
        project: Path,
        thread: dict,
        lease: LeaseToken | None = None,
    ) -> dict:
        """Auto-bind with CAS semantics; never replace an explicit binding."""
        key = str(project)
        thread_id = thread["id"]
        with self._lock(True):
            loaded = self._read()
            if loaded is not None:
                self.data = loaded
            existing = self.bindings.get(key)
            if existing is not None:
                if (
                    not isinstance(existing.get("agent"), str)
                    or not existing.get("agent")
                    or existing.get("project") != key
                    or not existing.get("threadId")
                ):
                    raise IdentityError(f"invalid stored binding identity for {project}")
                return dict(existing)
            for other_project, binding in self.bindings.items():
                if other_project != key and binding.get("threadId") == thread_id:
                    raise IdentityError(
                        f"thread {thread_id} is already bound to {other_project}"
                    )
            now = utc_now()
            binding = {
                "agent": lease.agent_id if lease is not None else "codex",
                "project": key,
                "threadId": thread_id,
                "sessionId": thread.get("sessionId"),
                "bindingRevision": uuid.uuid4().hex,
                "boundAt": now,
            }
            if lease is not None:
                binding.update(
                    {
                        "roundtableSessionId": lease.session_id,
                        "leaseRevision": lease.revision,
                    }
                )
            self.bindings[key] = binding
            self.data.setdefault("projects", {})[key] = {
                "phase": "EMPTY",
                "reboundAt": now,
            }
            atomic_json(self.path, self.data)
            return dict(binding)

    def bind_from_request(
        self,
        project: Path,
        thread: dict,
        lease: LeaseToken,
        *,
        source: str,
    ) -> tuple[dict, bool]:
        """CAS-bind a validated hook request under its current lease guard.

        An exact replay is idempotent.  Only a trusted ``clear`` SessionStart
        may move the same launcher lease to a new native thread.  A binding
        from an older lease may be replaced because the caller holds
        ``seat_shared_guard`` for ``lease``; a stale request cannot acquire
        that guard after a newer claim.
        """
        if source not in BIND_REQUEST_SOURCES:
            raise IdentityError(f"unsupported bind request source: {source!r}")
        key = str(project)
        thread_id = thread["id"]
        with self._lock(True):
            loaded = self._read()
            if loaded is not None:
                self.data = loaded
            existing = self.bindings.get(key)
            if existing is not None:
                if (
                    not isinstance(existing.get("agent"), str)
                    or not existing.get("agent")
                    or existing.get("project") != key
                    or not existing.get("threadId")
                ):
                    raise IdentityError(f"invalid stored binding identity for {project}")
                same_fence = (
                    existing.get("agent") == lease.agent_id
                    and existing.get("roundtableSessionId") == lease.session_id
                    and str(existing.get("leaseRevision")) == str(lease.revision)
                )
                if same_fence:
                    if existing.get("threadId") != thread_id:
                        if source != "clear":
                            raise IdentityError(
                                f"lease {lease.session_id} already binds a different "
                                f"Codex thread for {project}"
                            )
                    else:
                        return dict(existing), False
            for other_project, binding in self.bindings.items():
                if other_project != key and binding.get("threadId") == thread_id:
                    raise IdentityError(
                        f"thread {thread_id} is already bound to {other_project}"
                    )
            now = utc_now()
            binding = {
                "agent": lease.agent_id,
                "project": key,
                "threadId": thread_id,
                "sessionId": thread.get("sessionId"),
                "bindingRevision": uuid.uuid4().hex,
                "boundAt": now,
                "roundtableSessionId": lease.session_id,
                "leaseRevision": lease.revision,
            }
            self.bindings[key] = binding
            self.data.setdefault("projects", {})[key] = {
                "phase": "EMPTY",
                "reboundAt": now,
            }
            atomic_json(self.path, self.data)
            return dict(binding), True

    def unbind(self, project: Path) -> bool:
        key = str(project.expanduser().resolve())
        with self._lock(True):
            loaded = self._read()
            if loaded is not None:
                self.data = loaded
            removed_binding = self.bindings.pop(key, None) is not None
            removed_state = self.data.setdefault("projects", {}).pop(key, None) is not None
            if removed_binding or removed_state:
                atomic_json(self.path, self.data)
            return removed_binding or removed_state

    def quarantine_binding_if_revision(
        self,
        project: Path,
        binding_revision: str,
    ) -> bool:
        """Fail closed if a consumed bind request was concurrently replaced.

        The revision comparison ensures that an independently completed newer
        bind is never removed.  A successful later bind resets this persisted
        quarantine through the normal project-state replacement in bind().
        """
        key = str(project)
        with self._lock(True):
            loaded = self._read()
            if loaded is not None:
                self.data = loaded
            binding = self.bindings.get(key)
            if not isinstance(binding, dict) or (
                binding.get("bindingRevision") != binding_revision
            ):
                return False
            self.bindings.pop(key, None)
            self.data.setdefault("projects", {})[key] = {
                "phase": "BIND_QUARANTINED",
                "quarantinedAt": utc_now(),
                "bindingRevision": binding_revision,
                "lastError": (
                    "SessionStart request was replaced before consumption; "
                    "waiting for the replacement request"
                ),
            }
            atomic_json(self.path, self.data)
            return True


def _lease_environment(project: Path) -> LeaseToken | None:
    """Resolve and fence the lease carried by a Codex tool subprocess.

    Legacy direct binds remain accepted only before a project has any seat
    record. Once a unified launcher creates a lease, an old or unlaunched
    thread cannot replace its binding.
    """
    session_id = os.environ.get("RT_SESSION_ID")
    revision = os.environ.get("RT_LEASE_REVISION")
    configured_root = os.environ.get("RT_PROJECT_ROOT")
    configured_agent = os.environ.get("RT_FROM")
    inspection = inspect_seat(project, configured_agent or "codex")

    if inspection.status == "vacant":
        if session_id or revision or configured_root:
            raise IdentityError(
                f"claimed-seat environment exists but no current Codex lease "
                f"exists for {project}"
            )
        try:
            records = harness_lease_records(project, "codex")
        except RuntimeStateError as error:
            raise IdentityError(
                f"Codex seat state is ambiguous for {project}: {error}"
            ) from error
        if records:
            agents = ", ".join(
                sorted({str(record.get("agentId")) for record in records})
            )
            raise IdentityError(
                f"legacy bind is superseded by host-local Codex seat state "
                f"for {project} (agents: {agents})"
            )
        return None
    if inspection.status == "stale":
        raise IdentityError(
            f"Codex seat is inactive for {project}; launch a fresh session with rt-codex"
        )
    if inspection.status == "ambiguous":
        raise IdentityError(
            f"Codex seat state is ambiguous for {project}: {inspection.detail}"
        )
    token = inspection.token
    if token is None:
        raise IdentityError(f"Codex seat has no validated lease for {project}")
    if not session_id or revision is None:
        raise IdentityError(
            "RT_SESSION_ID and RT_LEASE_REVISION are required; "
            "launch this thread with rt-codex"
        )
    if configured_root:
        try:
            environment_root = Path(configured_root).expanduser().resolve()
        except (OSError, RuntimeError, ValueError) as error:
            raise IdentityError(f"invalid RT_PROJECT_ROOT: {error}") from error
        if environment_root != project:
            raise IdentityError(
                f"RT_PROJECT_ROOT {environment_root} does not match {project}"
            )
    if configured_agent and configured_agent != token.agent_id:
        raise IdentityError(
            f"RT_FROM={configured_agent!r} does not match current seat "
            f"{token.agent_id!r}"
        )
    try:
        return load_validated_lease(
            project,
            token.agent_id,
            session_id,
            revision,
        )
    except (FenceRejected, RuntimeStateError) as error:
        raise IdentityError(f"Codex seat lease validation failed: {error}") from error


def _binding_lease(project: Path, binding: dict) -> LeaseToken | None:
    """Return the active lease for a binding, or validate legacy compatibility."""
    agent_id = binding.get("agent")
    if not isinstance(agent_id, str) or not agent_id:
        raise IdentityError(f"stored binding lacks agent identity for {project}")
    session_id = binding.get("roundtableSessionId")
    revision = binding.get("leaseRevision")
    if bool(session_id) != (revision is not None):
        raise IdentityError(f"stored binding has partial lease identity for {project}")
    if not session_id:
        inspection = inspect_seat(project, agent_id)
        if inspection.status == "vacant":
            if agent_id != "codex":
                raise IdentityError(
                    f"legacy binding has unsupported agent {agent_id!r} for {project}"
                )
            try:
                records = harness_lease_records(project, "codex")
            except RuntimeStateError as error:
                raise IdentityError(
                    f"Codex seat state is ambiguous for {project}: {error}"
                ) from error
            if records:
                agents = ", ".join(
                    sorted({str(record.get("agentId")) for record in records})
                )
                raise IdentityError(
                    f"legacy binding is superseded by host-local seat state "
                    f"for {project} (agents: {agents})"
                )
            return None
        raise IdentityError(
            f"legacy binding is superseded by host-local seat state "
            f"({inspection.status}) for {project}; re-bind from rt-codex"
        )
    try:
        return load_validated_lease(project, agent_id, session_id, revision)
    except (FenceRejected, RuntimeStateError) as error:
        raise IdentityError(
            f"stored Codex binding does not match the active seat for {project}: {error}"
        ) from error


def _discover_binding_lease(project: Path) -> LeaseToken | None:
    """Find the only active configured Codex seat for explicit auto-discovery."""
    # P0's supported configuration names the Codex mailbox ``codex``.
    inspection = inspect_seat(project, "codex")
    if inspection.status == "vacant":
        try:
            records = harness_lease_records(project, "codex")
        except RuntimeStateError as error:
            raise IdentityError(
                f"cannot inspect Codex seat records for {project}: {error}"
            ) from error
        if records:
            agents = ", ".join(
                sorted({str(record.get("agentId")) for record in records})
            )
            raise IdentityError(
                f"cannot auto-bind while another Codex seat record exists "
                f"for {project} (agents: {agents})"
            )
        return None
    if inspection.status == "stale":
        raise IdentityError(
            f"cannot auto-bind an inactive Codex seat for {project}; relaunch rt-codex"
        )
    if inspection.status == "ambiguous" or inspection.token is None:
        raise IdentityError(
            f"cannot auto-bind ambiguous Codex seat for {project}: {inspection.detail}"
        )
    return inspection.token


def heartbeat_bound_seats(
    store: StateStore,
    projects: list[Path],
    results: list["ProjectResult"],
) -> None:
    """Refresh per-seat wake health after successful bridge iterations."""
    for project, result in zip(projects, results):
        if not result.ok:
            continue
        binding = store.bindings.get(str(project))
        if not isinstance(binding, dict):
            continue
        try:
            lease = _binding_lease(project, binding)
            if lease is None:
                continue
            update_wake(
                project,
                lease.agent_id,
                lease.session_id,
                lease.revision,
                native_session_id=binding.get("threadId"),
            )
        except (IdentityError, FenceRejected, RuntimeStateError) as error:
            log_event(
                "seat_heartbeat_rejected",
                project=str(project),
                error=str(error),
            )


def log_event(event: str, **fields) -> None:
    RUNTIME_DIR.mkdir(parents=True, exist_ok=True, mode=0o700)
    path = RUNTIME_DIR / "rt-codex-wake.log.jsonl"
    record = {"ts": utc_now(), "event": event, **fields}
    descriptor = os.open(path, os.O_WRONLY | os.O_APPEND | os.O_CREAT, 0o600)
    with os.fdopen(descriptor, "a", encoding="utf-8") as handle:
        handle.write(json.dumps(record, ensure_ascii=False, sort_keys=True) + "\n")


def notify_needs_human(
    project: Path,
    thread_id: str,
    generation: str,
    turn_id: str | None,
    source: str,
    reason: str,
) -> None:
    """Emit one durable event and make one best-effort desktop notification."""
    fields = {
        "project": str(project),
        "thread_id": thread_id,
        "generation": generation,
        "turn_id": turn_id,
        "source": source,
        "reason": reason,
    }
    log_event("wake_needs_human", **fields)
    title = "Roundtable Codex needs human"
    subtitle = project.name
    body = f"{reason[:300]} Inbox remains pending."
    failures = []

    cmux = shutil.which("cmux")
    if cmux:
        try:
            result = subprocess.run(
                [
                    cmux,
                    "notify",
                    "--title",
                    title,
                    "--subtitle",
                    subtitle,
                    "--body",
                    body,
                ],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                timeout=2,
                check=False,
            )
            if result.returncode == 0:
                log_event(
                    "needs_human_notification_sent",
                    **fields,
                    provider="cmux",
                )
                return
            failures.append(f"cmux exit {result.returncode}")
        except (OSError, subprocess.TimeoutExpired) as error:
            failures.append(f"cmux {type(error).__name__}")
    else:
        failures.append("cmux unavailable")

    # Terminal.app, iTerm2, Ghostty, and other hosts share the native macOS
    # notification baseline. cmux above is only a workspace-aware enhancement.
    osascript = shutil.which("osascript")
    if osascript:
        script = (
            "on run argv\n"
            "display notification (item 3 of argv) with title (item 1 of argv) "
            "subtitle (item 2 of argv)\n"
            "end run"
        )
        try:
            result = subprocess.run(
                [osascript, "-e", script, "--", title, subtitle, body],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                timeout=2,
                check=False,
            )
            if result.returncode == 0:
                log_event(
                    "needs_human_notification_sent",
                    **fields,
                    provider="macos",
                )
                return
            failures.append(f"osascript exit {result.returncode}")
        except (OSError, subprocess.TimeoutExpired) as error:
            failures.append(f"osascript {type(error).__name__}")
    else:
        failures.append("osascript unavailable")

    log_event(
        "needs_human_notification_failed",
        **fields,
        error="; ".join(failures),
    )


def canonical_project(path: Path) -> Path:
    try:
        project = path.expanduser().resolve()
    except (OSError, RuntimeError, ValueError) as error:
        raise IdentityError(f"cannot resolve project root {path}: {error}") from error
    if not (project / ".roundtable" / "agents.yaml").is_file():
        raise IdentityError(f"not a Roundtable project: {project}")
    return project


def bind_requests_dir(root: Path | None = None) -> Path:
    selected = Path(RUNTIME_DIR if root is None else root).expanduser()
    if not selected.is_absolute():
        raise UnsafeBindRequest(f"runtime root is not absolute: {selected}")
    return selected / BIND_REQUESTS_DIRNAME


def _validate_private_directory(path: Path) -> None:
    try:
        info = path.lstat()
    except FileNotFoundError:
        raise
    except OSError as error:
        raise UnsafeBindRequest(f"cannot inspect request directory {path}: {error}") from error
    if stat.S_ISLNK(info.st_mode) or not stat.S_ISDIR(info.st_mode):
        raise UnsafeBindRequest(f"request path is not a real directory: {path}")
    if info.st_uid != os.getuid():
        raise UnsafeBindRequest(
            f"request directory owner uid {info.st_uid} != {os.getuid()}: {path}"
        )
    if info.st_mode & 0o077:
        raise UnsafeBindRequest(
            f"request directory exposes group/other permissions: {path}"
        )


def _read_bind_request(path: Path) -> tuple[dict, tuple[int, int]]:
    try:
        info = path.lstat()
    except OSError as error:
        raise UnsafeBindRequest(f"cannot inspect bind request {path}: {error}") from error
    if stat.S_ISLNK(info.st_mode) or not stat.S_ISREG(info.st_mode):
        raise UnsafeBindRequest(f"bind request is not a regular file: {path}")
    if info.st_uid != os.getuid():
        raise UnsafeBindRequest(
            f"bind request owner uid {info.st_uid} != {os.getuid()}: {path}"
        )
    if info.st_mode & 0o077:
        raise UnsafeBindRequest(
            f"bind request exposes group/other permissions: {path}"
        )
    flags = os.O_RDONLY
    flags |= getattr(os, "O_CLOEXEC", 0)
    flags |= getattr(os, "O_NOFOLLOW", 0)
    try:
        descriptor = os.open(path, flags)
    except OSError as error:
        if error.errno == errno.ELOOP:
            raise UnsafeBindRequest(f"bind request became a symlink: {path}") from error
        raise UnsafeBindRequest(f"cannot open bind request {path}: {error}") from error
    with os.fdopen(descriptor, "rb") as handle:
        opened = os.fstat(handle.fileno())
        if not stat.S_ISREG(opened.st_mode):
            raise UnsafeBindRequest(f"opened bind request is not regular: {path}")
        if opened.st_uid != os.getuid() or opened.st_mode & 0o077:
            raise UnsafeBindRequest(f"opened bind request is not private: {path}")
        raw = handle.read(BIND_REQUEST_MAX_BYTES + 1)
    identity = (opened.st_dev, opened.st_ino)
    if len(raw) > BIND_REQUEST_MAX_BYTES:
        raise MalformedBindRequest(
            f"bind request is too large: {path.name}", identity
        )
    try:
        payload = json.loads(raw.decode("utf-8"))
    except (UnicodeError, json.JSONDecodeError) as error:
        raise MalformedBindRequest(
            f"bind request is not valid UTF-8 JSON: {path.name}", identity
        ) from error
    if not isinstance(payload, dict):
        raise MalformedBindRequest(
            f"bind request is not an object: {path.name}", identity
        )
    return payload, identity


def _consume_bind_request(path: Path, identity: tuple[int, int]) -> bool:
    """Unlink only the exact private regular file that was inspected."""
    try:
        with bind_request_guard(path.parent.parent):
            try:
                current = path.lstat()
            except FileNotFoundError:
                return True
            except OSError:
                return False
            if (
                stat.S_ISLNK(current.st_mode)
                or not stat.S_ISREG(current.st_mode)
                or current.st_uid != os.getuid()
                or (current.st_dev, current.st_ino) != identity
            ):
                return False
            try:
                path.unlink()
            except FileNotFoundError:
                return True
            except OSError:
                return False
            return True
    except RuntimeStateError:
        return False


def _request_text(payload: dict, name: str) -> str:
    value = payload.get(name)
    if not isinstance(value, str) or not value or "\0" in value:
        raise MalformedBindRequest(f"bind request field {name} is invalid")
    try:
        encoded = value.encode("utf-8")
    except UnicodeError as error:
        raise MalformedBindRequest(
            f"bind request field {name} is not valid UTF-8 text"
        ) from error
    if len(encoded) > 4096:
        raise MalformedBindRequest(f"bind request field {name} is invalid")
    return value


def _validated_bind_request(
    path: Path,
    payload: dict,
    allowed_projects: set[str],
) -> tuple[Path, str, str, str, str]:
    if payload.get("schema") != BIND_REQUEST_SCHEMA:
        raise MalformedBindRequest("bind request schema is invalid")
    if payload.get("hookEventName") != "SessionStart":
        raise MalformedBindRequest("bind request hook event is invalid")
    source = _request_text(payload, "source")
    if source not in BIND_REQUEST_SOURCES:
        raise MalformedBindRequest("bind request SessionStart source is invalid")
    raw_project = _request_text(payload, "projectRoot")
    agent_id = _request_text(payload, "agentId")
    roundtable_session_id = _request_text(payload, "roundtableSessionId")
    lease_revision = _request_text(payload, "leaseRevision")
    thread_id = _request_text(payload, "threadId")
    created_at = _request_text(payload, "createdAt")
    try:
        parsed = datetime.fromisoformat(created_at.replace("Z", "+00:00"))
    except ValueError as error:
        raise MalformedBindRequest("bind request createdAt is invalid") from error
    if parsed.tzinfo is None:
        raise MalformedBindRequest("bind request createdAt lacks a timezone")
    # Hook-produced project roots are already canonical absolute paths.  Do not
    # expand a hostile ``~user`` value before proving that invariant: pathlib
    # raises RuntimeError when that account cannot be resolved.
    raw_path = Path(raw_project)
    if not raw_path.is_absolute():
        raise MalformedBindRequest("bind request projectRoot is not absolute")
    try:
        project = canonical_project(raw_path)
    except (IdentityError, OSError, RuntimeError) as error:
        raise MalformedBindRequest(str(error)) from error
    if raw_project != str(project):
        raise MalformedBindRequest("bind request projectRoot is not canonical")
    if str(project) not in allowed_projects:
        raise IdentityError(f"bind request project is not registered: {project}")
    identity = "\0".join(
        (
            str(project),
            agent_id,
            roundtable_session_id,
            lease_revision,
        )
    )
    expected_name = f"{hashlib.sha256(identity.encode('utf-8')).hexdigest()}.json"
    if path.name != expected_name:
        raise MalformedBindRequest("bind request filename does not match its identity")
    return project, agent_id, roundtable_session_id, lease_revision, thread_id


def project_config_has_codex(project: Path) -> bool:
    """Strictly recognize a top-level agents.codex.harness=codex block."""
    document = load_agents_doc(project, "rt-codex-wake")
    if not isinstance(document, dict):
        return False
    configured_project = document.get("project")
    agents = document.get("agents")
    if not isinstance(configured_project, str) or not isinstance(agents, dict):
        return False
    codex = agents.get("codex")
    if not isinstance(codex, dict) or codex.get("harness") != "codex":
        return False
    try:
        configured_path = Path(configured_project).expanduser()
        # New project configs use ``project: "."`` so a cloned repository keeps
        # its Roundtable identity. Resolve that value relative to the config's
        # project root, not the wake bridge's launchd working directory. Keep
        # accepting absolute paths emitted by older Roundtable releases.
        if not configured_path.is_absolute():
            configured_path = project / configured_path
        project_matches = configured_path.resolve() == project
    except (OSError, RuntimeError):
        project_matches = False
    return project_matches


def validate_thread(project: Path, thread: dict, expected_id: str | None = None) -> dict:
    if not project_config_has_codex(project):
        raise IdentityError(f"agents.yaml does not configure agents.codex.harness=codex: {project}")
    if expected_id and thread.get("id") != expected_id:
        raise IdentityError(
            f"thread id mismatch: expected {expected_id}, got {thread.get('id')}"
        )
    try:
        thread_cwd = Path(thread["cwd"]).expanduser().resolve()
    except (KeyError, TypeError, OSError, RuntimeError, ValueError) as error:
        raise IdentityError(f"thread has invalid cwd: {error}") from error
    if thread_cwd != project:
        raise IdentityError(f"thread cwd mismatch: {thread_cwd} != {project}")
    # A local embedded TUI reports `cli`; a TUI attached through --remote is
    # serialized as `vscode`. Depending on how the interactive turn reached
    # app-server, threadSource may be either `user` or absent. For explicit
    # CODEX_THREAD_ID self-registration, the exact id plus cwd is the primary
    # identity proof; this source allowlist remains a secondary guard against
    # binding exec, sub-agent, or other non-interactive thread kinds.
    source = thread.get("source")
    thread_source = thread.get("threadSource")
    if source not in ("cli", "vscode"):
        raise IdentityError(f"thread source is not a supported TUI: {source!r}")
    if source == "vscode" and thread_source not in (None, "user"):
        raise IdentityError(
            f"remote TUI threadSource is not user: {thread_source!r}"
        )
    if source == "cli" and thread_source not in (None, "user"):
        raise IdentityError(
            f"threadSource is not user: {thread_source!r}"
        )
    if thread.get("parentThreadId") is not None:
        raise IdentityError("refusing to bind a sub-agent thread")
    if thread.get("ephemeral") is not False:
        raise IdentityError("refusing to bind an ephemeral thread")
    return thread


def read_thread(client: AppServerClient, thread_id: str) -> dict:
    result = client.request(
        "thread/read", {"threadId": thread_id, "includeTurns": False}
    )
    if not isinstance(result, dict):
        raise IdentityError("thread/read returned an invalid result")
    thread = result.get("thread")
    if not isinstance(thread, dict):
        raise IdentityError("thread/read returned an invalid thread")
    return thread


def drain_bind_requests(
    client: AppServerClient,
    store: StateStore,
    projects: list[Path],
    *,
    requests_dir: Path | None = None,
    quarantined_projects: set[str] | None = None,
) -> set[str]:
    """Validate and CAS-apply SessionStart requests outside the hook call."""
    queue = bind_requests_dir() if requests_dir is None else Path(requests_dir)
    try:
        _validate_private_directory(queue.parent)
        _validate_private_directory(queue)
    except FileNotFoundError:
        return set()
    except UnsafeBindRequest as error:
        log_event("auto_bind_queue_unsafe", path=str(queue), error=str(error))
        return set()
    try:
        entries = sorted(queue.iterdir())
    except OSError as error:
        log_event("auto_bind_queue_unsafe", path=str(queue), error=str(error))
        return set()

    allowed_projects = set()
    for candidate in projects:
        try:
            allowed_projects.add(str(candidate.expanduser().resolve()))
        except (OSError, RuntimeError) as error:
            # Registry projects are canonical when discovered, but the path can
            # be replaced between discovery and a bridge iteration.  Isolate
            # that project instead of letting one symlink loop stop every bind.
            log_event(
                "auto_bind_project_unsafe",
                project=str(candidate),
                error=str(error),
            )
    changed: set[str] = set()
    for path in entries:
        if path.name.startswith("."):
            continue
        identity = None
        try:
            payload, identity = _read_bind_request(path)
            (
                project,
                agent_id,
                roundtable_session_id,
                lease_revision,
                thread_id,
            ) = _validated_bind_request(path, payload, allowed_projects)
            source = payload["source"]
            with seat_shared_guard(
                project,
                agent_id,
                roundtable_session_id,
                lease_revision,
            ) as current:
                if current.harness != "codex":
                    raise IdentityError(
                        f"bind request lease is for harness {current.harness!r}, not codex"
                    )
                selected_thread = validate_thread(
                    project,
                    read_thread(client, thread_id),
                    thread_id,
                )
                binding, did_change = store.bind_from_request(
                    project,
                    selected_thread,
                    current,
                    source=source,
                )
                update_wake(
                    project,
                    current.agent_id,
                    current.session_id,
                    current.revision,
                    native_session_id=thread_id,
                )
            if did_change:
                changed.add(str(project))
            consumed = _consume_bind_request(path, identity)
            quarantined = False
            if not consumed:
                # A clear may atomically replace this path after it was opened.
                # The validated old thread must not receive mail during the
                # resulting one-iteration handoff.  Remove only the binding we
                # just observed; a concurrently completed newer bind wins.
                if quarantined_projects is not None:
                    quarantined_projects.add(str(project))
                quarantined = store.quarantine_binding_if_revision(
                    project,
                    binding.get("bindingRevision"),
                )
            elif quarantined_projects is not None:
                # A fully validated replacement request has now been applied
                # and consumed, so routing may resume in this iteration.
                quarantined_projects.discard(str(project))
            log_event(
                "auto_bind_succeeded",
                project=str(project),
                agent=agent_id,
                thread_id=thread_id,
                binding_revision=binding.get("bindingRevision"),
                changed=did_change,
                request_consumed=consumed,
                binding_quarantined=quarantined,
            )
        except UnsafeBindRequest as error:
            # Do not unlink an entry that was never proven to be the private
            # regular file we intended to inspect.
            log_event("auto_bind_request_unsafe", path=str(path), error=str(error))
        except (MalformedBindRequest, IdentityError, FenceRejected, RuntimeStateError) as error:
            if identity is None and isinstance(error, MalformedBindRequest):
                identity = error.identity
            consumed = bool(identity) and _consume_bind_request(path, identity)
            log_event(
                "auto_bind_rejected",
                path=str(path),
                error=str(error),
                request_consumed=consumed,
            )
        except (RpcError, OSError, TimeoutError) as error:
            # A valid current request survives transient app-server or I/O
            # failure and is retried on the next bridge iteration.
            log_event("auto_bind_deferred", path=str(path), error=str(error))
    return changed


def resume_thread(client: AppServerClient, project: Path, thread_id: str) -> dict:
    # Read validates identity without silently rebinding by cwd or recency.
    validate_thread(project, read_thread(client, thread_id), thread_id)
    result = client.request(
        "thread/resume", {"threadId": thread_id, "excludeTurns": True}
    )
    if not isinstance(result, dict) or not isinstance(result.get("thread"), dict):
        raise IdentityError("thread/resume returned an invalid thread")
    return validate_thread(project, result["thread"], thread_id)


def resume_or_loaded(
    client: AppServerClient, project: Path, thread_id: str
) -> tuple[dict, bool]:
    """Resume and subscribe, or accept a live zero-turn TUI with no rollout yet."""
    try:
        return resume_thread(client, project, thread_id), True
    except RpcError as error:
        expected = f"no rollout found for thread id {thread_id}"
        if expected not in str(error):
            raise
        loaded = validate_thread(
            project, read_thread(client, thread_id), thread_id
        )
        if status_type(loaded) == "notLoaded":
            raise
        return loaded, False


def discover_thread(client: AppServerClient, project: Path) -> dict:
    loaded = []
    cursor = None
    seen_cursors = set()
    while True:
        params = {"cursor": cursor} if cursor else {}
        page = client.request("thread/loaded/list", params)
        loaded.extend(page.get("data") or [])
        cursor = page.get("nextCursor")
        if not cursor:
            break
        if cursor in seen_cursors:
            raise IdentityError("thread/loaded/list returned a repeated cursor")
        seen_cursors.add(cursor)
    candidates = []
    for thread_id in loaded:
        try:
            candidate = validate_thread(
                project, read_thread(client, thread_id), thread_id
            )
            # App-server labels every external client `vscode`, including both
            # rt-codex remote TUIs and real IDE sessions. That union is not a
            # safe auto-binding identity. Remote TUIs must self-register with
            # `bind`; only an embedded local CLI is auto-discoverable.
            if candidate.get("source") == "cli":
                candidates.append(candidate)
        except IdentityError:
            continue
    if len(candidates) != 1:
        raise IdentityError(
            f"expected exactly one auto-discoverable local CLI root thread for {project}, "
            f"found {len(candidates)}; run rt-codex-wake bind from the target Codex turn"
        )
    return candidates[0]


def pending_generation(
    project: Path,
    agent_id: str = "codex",
) -> tuple[str | None, list[str]]:
    if not isinstance(agent_id, str) or not agent_id:
        raise IdentityError("Codex binding lacks a valid agent identity")
    inbox = project / ".roundtable" / "inbox" / agent_id / "new"
    inbox.mkdir(parents=True, exist_ok=True)
    ids = []
    for path in sorted(inbox.iterdir()):
        if path.name.startswith(".") or path.name.startswith("ack-"):
            continue
        try:
            info = path.lstat()
        except FileNotFoundError:
            # The target Codex may drain new/ to cur/ while we scan.
            continue
        if stat.S_ISLNK(info.st_mode) or not stat.S_ISREG(info.st_mode):
            raise IdentityError(f"invalid non-regular inbox entry: {path}")
        if path.suffix != ".md":
            raise IdentityError(f"invalid inbox filename: {path.name}")
        flags = os.O_RDONLY | getattr(os, "O_CLOEXEC", 0) | getattr(os, "O_NOFOLLOW", 0)
        try:
            descriptor = os.open(path, flags)
        except FileNotFoundError:
            continue
        except OSError as error:
            if error.errno == errno.ELOOP:
                raise IdentityError(f"invalid symlink inbox entry: {path}") from error
            raise
        with os.fdopen(descriptor, "rb") as handle:
            opened = os.fstat(handle.fileno())
            if not stat.S_ISREG(opened.st_mode):
                raise IdentityError(f"invalid non-regular inbox entry: {path}")
            prefix = handle.read(16 * 1024 + 1)
        end = prefix.find(b"]")
        if end < 0:
            raise IdentityError(f"oversized or incomplete Roundtable mail header: {path.name}")
        raw_header = prefix[: end + 1]
        try:
            header = raw_header.decode("utf-8")
        except UnicodeDecodeError as error:
            raise IdentityError(f"invalid UTF-8 mail header: {path.name}") from error
        match = MAIL_RE.match(header)
        if not match:
            raise IdentityError(f"invalid Roundtable mail header: {path.name}")
        msg_id = match.group("id")
        if match.group("to").lower() != agent_id.lower() or msg_id != path.stem:
            raise IdentityError(f"mail identity mismatch: {path.name}")
        ids.append(msg_id)
    if not ids:
        return None, []
    digest = hashlib.sha256("\n".join(ids).encode()).hexdigest()
    return digest, ids


def status_type(thread: dict) -> str:
    status = thread.get("status") or {}
    return status.get("type", "unknown") if isinstance(status, dict) else "unknown"


def safe_timestamp(value) -> float:
    try:
        parsed = float(value or 0)
    except (TypeError, ValueError, OverflowError):
        return 0.0
    return parsed if math.isfinite(parsed) and parsed >= 0 else 0.0


def safe_counter(value) -> int:
    try:
        parsed = int(value or 0)
    except (TypeError, ValueError, OverflowError):
        return 0
    return max(0, parsed)


@dataclass
class ProjectResult:
    ok: bool
    detail: str


class WakeBridge:
    def __init__(
        self,
        client: AppServerClient,
        projects: list[Path],
        store: StateStore,
        *,
        auto_discover: bool = False,
    ):
        self.client = client
        self.projects = projects
        self.store = store
        self.auto_discover = auto_discover
        self.resumed: dict[str, dict] = {}
        self.completed_threads: set[str] = set()
        self.completions: dict[str, list[dict]] = {}
        self.active_observed: set[str] = set()
        self.resume_attempted: set[str] = set()
        self.subscribed_threads: set[str] = set()
        self.bind_quarantined: set[str] = set()

    @staticmethod
    def _request_key(request_id) -> str:
        try:
            return json.dumps(request_id, sort_keys=True, separators=(",", ":"))
        except (TypeError, ValueError):
            return repr(request_id)

    def consume_messages(self, messages: list[dict]) -> None:
        for message in messages:
            if message.get("method") == "serverRequest/resolved":
                params = message.get("params") or {}
                resolved = self._resolve_human_request(
                    params.get("requestId"), params.get("threadId")
                )
                if not resolved:
                    log_event(
                        "server_request_resolution_ignored",
                        thread_id=params.get("threadId"),
                    )
                continue
            if "id" in message and "method" in message:
                # App-server multicasts approval/user-input requests to thread
                # subscribers and the first response wins. The human-facing
                # TUI owns those decisions; the bridge must not race it with a
                # synthetic approval or denial. A missing TUI therefore fails
                # safe (mail remains in new/) and is visible in this log.
                method = message.get("method")
                params = message.get("params") or {}
                thread_id = params.get("threadId")
                turn_id = params.get("turnId")
                auto_resolves = (
                    method == "item/tool/requestUserInput"
                    and params.get("autoResolutionMs") is not None
                )
                request_id = message.get("id")
                valid_request_id = isinstance(request_id, (str, int)) and not isinstance(
                    request_id, bool
                )
                if (
                    method in HUMAN_DECISION_METHODS
                    and thread_id
                    and valid_request_id
                    and not auto_resolves
                    and self._record_human_request(
                        request_id, method, thread_id, turn_id
                    )
                ):
                    log_event(
                        "human_decision_requested",
                        method=method,
                        thread_id=thread_id,
                        turn_id=turn_id or "bridge-owned-wake",
                    )
                else:
                    log_event("server_request_ignored", method=method)
                continue
            if message.get("method") != "turn/completed":
                continue
            params = message.get("params") or {}
            thread_id = params.get("threadId")
            if thread_id:
                self.completed_threads.add(thread_id)
                turn = params.get("turn") or {}
                self.completions.setdefault(thread_id, []).append(
                    {"turnId": turn.get("id"), "status": turn.get("status")}
                )

    def _record_human_request(
        self,
        request_id: str | int,
        method: str,
        thread_id: str,
        turn_id: str | None,
    ) -> bool:
        request_key = self._request_key(request_id)
        with self.store.transaction():
            for project in self.projects:
                binding = self.store.bindings.get(str(project)) or {}
                project_state = self.store.project_state(project)
                wake_turn_id = project_state.get("lastWakeTurnId")
                effective_turn_id = turn_id
                if method == "mcpServer/elicitation/request" and not effective_turn_id:
                    effective_turn_id = wake_turn_id
                if (
                    binding.get("threadId") != thread_id
                    or project_state.get("lastWakeThreadId") != thread_id
                    or not project_state.get("lastWakeGeneration")
                    or not wake_turn_id
                    or effective_turn_id != wake_turn_id
                ):
                    continue
                pending = project_state.get("pendingHumanRequests")
                if not isinstance(pending, dict):
                    pending = {}
                    project_state["pendingHumanRequests"] = pending
                pending[request_key] = {
                    "method": method,
                    "threadId": thread_id,
                    "turnId": effective_turn_id,
                    "generation": project_state["lastWakeGeneration"],
                    "observedAt": utc_now(),
                }
                self.store.flush_transaction()
                return True
        return False

    def _resolve_human_request(self, request_id, thread_id) -> bool:
        if not isinstance(request_id, (str, int)) or isinstance(request_id, bool):
            return False
        request_key = self._request_key(request_id)
        with self.store.transaction():
            projects = self.store.data.setdefault("projects", {})
            for project_state in projects.values():
                pending = project_state.get("pendingHumanRequests")
                if not isinstance(pending, dict):
                    continue
                record = pending.get(request_key)
                if not isinstance(record, dict) or record.get("threadId") != thread_id:
                    continue
                pending.pop(request_key, None)
                if not pending:
                    project_state.pop("pendingHumanRequests", None)
                self.store.flush_transaction()
                return True
        return False

    @staticmethod
    def _pending_human_methods(
        project_state: dict, thread_id: str, turn_id: str | None, generation: str
    ) -> list[str]:
        if not turn_id:
            return []
        pending = project_state.get("pendingHumanRequests")
        if not isinstance(pending, dict):
            return []
        methods = {
            record.get("method")
            for record in pending.values()
            if isinstance(record, dict)
            and record.get("threadId") == thread_id
            and record.get("turnId") == turn_id
            and record.get("generation") == generation
            and isinstance(record.get("method"), str)
        }
        return sorted(methods)

    @staticmethod
    def _drop_pending_human_requests(
        project_state: dict, thread_id: str, turn_id: str | None
    ) -> bool:
        pending = project_state.get("pendingHumanRequests")
        if not isinstance(pending, dict):
            if "pendingHumanRequests" in project_state:
                project_state.pop("pendingHumanRequests", None)
                return True
            return False
        doomed = [
            request_key
            for request_key, record in pending.items()
            if isinstance(record, dict)
            and record.get("threadId") == thread_id
            and record.get("turnId") == turn_id
        ]
        for request_key in doomed:
            pending.pop(request_key, None)
        if not pending:
            project_state.pop("pendingHumanRequests", None)
        return bool(doomed)

    def _clear_pending_human_requests(
        self, project: Path, thread_id: str, turn_id: str | None
    ) -> None:
        with self.store.transaction():
            project_state = self.store.project_state(project)
            if self._drop_pending_human_requests(
                project_state, thread_id, turn_id
            ):
                self.store.flush_transaction()

    def _thread_for(self, project: Path) -> dict:
        key = str(project)
        binding = self.store.bindings.get(key)
        if binding:
            if binding.get("project") != key:
                raise IdentityError(f"invalid stored binding identity for {project}")
            _binding_lease(project, binding)
            thread_id = binding.get("threadId")
            if not thread_id:
                raise IdentityError(f"stored binding lacks threadId for {project}")
            if (
                key not in self.resumed
                or self.resumed[key].get("id") != thread_id
            ):
                self.resume_attempted.add(key)
                self.resumed[key], subscribed = resume_or_loaded(
                    self.client, project, thread_id
                )
                if subscribed:
                    self.subscribed_threads.add(thread_id)
            return self.resumed[key]

        if not self.auto_discover:
            raise IdentityError(
                f"project has no explicit Codex binding: {project}; "
                "run rt-codex-wake bind from its target Codex turn"
            )
        thread = discover_thread(self.client, project)
        lease = _discover_binding_lease(project)
        if lease is None:
            try:
                with legacy_harness_guard(project, "codex"):
                    binding = self.store.bind_if_absent(project, thread)
            except RuntimeStateError as error:
                raise IdentityError(
                    f"Codex seat changed before legacy auto-bind: {error}"
                ) from error
        else:
            try:
                with seat_shared_guard(
                    project,
                    lease.agent_id,
                    lease.session_id,
                    lease.revision,
                ) as current:
                    binding = self.store.bind_if_absent(
                        project,
                        thread,
                        lease=current,
                    )
            except (FenceRejected, RuntimeStateError) as error:
                raise IdentityError(
                    f"Codex seat changed before auto-bind: {error}"
                ) from error
        _binding_lease(project, binding)
        self.resume_attempted.add(key)
        self.resumed[key], subscribed = resume_or_loaded(
            self.client, project, binding["threadId"]
        )
        if subscribed:
            self.subscribed_threads.add(binding["threadId"])
        else:
            log_event(
                "fresh_thread_loaded_without_rollout",
                project=str(project),
                thread_id=binding["threadId"],
            )
        return self.resumed[key]

    def _refresh(self, project: Path, thread_id: str) -> dict:
        thread = validate_thread(project, read_thread(self.client, thread_id), thread_id)
        if status_type(thread) == "notLoaded":
            thread = resume_thread(self.client, project, thread_id)
            self.subscribed_threads.add(thread_id)
        self.resumed[str(project)] = thread
        return thread

    def _hook_trust_gate(self, project: Path) -> str | None:
        result = self.client.request("hooks/list", {"cwds": [str(project)]})
        data = result.get("data")
        if not isinstance(data, list):
            raise IdentityError("hooks/list returned invalid data")
        matches = []
        for entry in data:
            if not isinstance(entry, dict):
                continue
            cwd_value = entry.get("cwd")
            if not isinstance(cwd_value, str) or not cwd_value:
                continue
            try:
                cwd = Path(cwd_value).expanduser().resolve()
            except (OSError, RuntimeError, ValueError):
                continue
            if cwd == project:
                matches.append(entry)
        if len(matches) != 1:
            raise IdentityError(
                f"hooks/list expected one entry for {project}, found {len(matches)}"
            )
        entry = matches[0]
        errors = entry.get("errors")
        if not isinstance(errors, list):
            raise IdentityError("hooks/list entry has invalid errors")
        if errors:
            raise IdentityError(f"hooks/list reported {len(errors)} discovery error(s)")
        hooks = entry.get("hooks")
        if not isinstance(hooks, list):
            raise IdentityError("hooks/list entry has invalid hooks")
        blockers = []
        for hook in hooks:
            if not isinstance(hook, dict) or not hook.get("enabled"):
                continue
            trust_status = hook.get("trustStatus")
            if trust_status not in {"managed", "trusted", "untrusted", "modified"}:
                raise IdentityError(
                    "hooks/list returned unknown trustStatus for enabled hook: "
                    f"{trust_status!r}"
                )
            if trust_status in {"untrusted", "modified"}:
                blockers.append(f"{hook.get('key') or 'unknown'}={trust_status}")
        if not blockers:
            return None
        sample = ", ".join(blockers[:3])
        if len(blockers) > 3:
            sample += f", +{len(blockers) - 3} more"
        return f"enabled Codex hook trust review required: {sample}"

    def _mark_needs_human(
        self,
        project: Path,
        thread_id: str,
        generation: str,
        turn_id: str | None,
        pending_count: int,
        source: str,
        reason: str,
        *,
        expected_binding_revision,
        state_updates: dict | None = None,
    ) -> ProjectResult:
        now = utc_now()
        with self.store.transaction():
            current_binding = self.store.bindings.get(str(project)) or {}
            if (
                current_binding.get("threadId") != thread_id
                or current_binding.get("bindingRevision")
                != expected_binding_revision
            ):
                return ProjectResult(False, "binding changed before needs-human latch")
            project_state = self.store.project_state(project)
            existing = project_state.get("needsHuman")
            if project_state.get("phase") == "NEEDS_HUMAN" and isinstance(
                existing, dict
            ):
                return ProjectResult(
                    False, f"needs human: {existing.get('reason') or 'manual recovery required'}"
                )
            if state_updates:
                project_state.update(state_updates)
            self._drop_pending_human_requests(project_state, thread_id, turn_id)
            project_state.update(
                {
                    "phase": "NEEDS_HUMAN",
                    "pendingCount": pending_count,
                    "retryAt": 0,
                    "lastError": reason,
                    "needsHuman": {
                        "generation": generation,
                        "threadId": thread_id,
                        "turnId": turn_id,
                        "source": source,
                        "reason": reason,
                        "detectedAt": now,
                        "notificationAttemptedAt": now,
                    },
                }
            )
            self.store.flush_transaction()
        notify_needs_human(
            project,
            thread_id,
            generation,
            turn_id,
            source,
            reason,
        )
        return ProjectResult(False, f"needs human: {reason}")

    def _latch_pending_human_if_any(
        self,
        project: Path,
        thread_id: str,
        generation: str,
        turn_id: str | None,
        pending_count: int,
        *,
        expected_binding_revision,
    ) -> ProjectResult | None:
        now = utc_now()
        with self.store.transaction():
            current_binding = self.store.bindings.get(str(project)) or {}
            if (
                current_binding.get("threadId") != thread_id
                or current_binding.get("bindingRevision")
                != expected_binding_revision
            ):
                return ProjectResult(False, "binding changed before needs-human latch")
            project_state = self.store.project_state(project)
            if (
                project_state.get("lastWakeGeneration") != generation
                or project_state.get("lastWakeThreadId") != thread_id
                or project_state.get("lastWakeTurnId") != turn_id
            ):
                return ProjectResult(False, "wake state changed before needs-human latch")
            methods = self._pending_human_methods(
                project_state, thread_id, turn_id, generation
            )
            if not methods:
                return None
            reason = "wake turn requires human decision: " + ",".join(methods)
            self._drop_pending_human_requests(project_state, thread_id, turn_id)
            project_state.update(
                {
                    "phase": "NEEDS_HUMAN",
                    "pendingCount": pending_count,
                    "retryAt": 0,
                    "lastError": reason,
                    "needsHuman": {
                        "generation": generation,
                        "threadId": thread_id,
                        "turnId": turn_id,
                        "source": "server_request",
                        "reason": reason,
                        "detectedAt": now,
                        "notificationAttemptedAt": now,
                    },
                }
            )
            self.store.flush_transaction()
        notify_needs_human(
            project,
            thread_id,
            generation,
            turn_id,
            "server_request",
            reason,
        )
        return ProjectResult(False, f"needs human: {reason}")

    def _wake(
        self,
        project: Path,
        thread_id: str,
        generation: str,
        count: int,
        *,
        expected_binding_revision,
    ) -> bool:
        binding = self.store.bindings.get(str(project)) or {}
        lease = _binding_lease(project, binding)
        agent_id = lease.agent_id if lease is not None else binding.get("agent")
        if not isinstance(agent_id, str) or not agent_id:
            raise IdentityError(f"Codex binding lacks agent identity for {project}")
        if lease is None:
            try:
                with legacy_harness_guard(project, "codex"):
                    return self._wake_guarded(
                        project,
                        agent_id,
                        thread_id,
                        generation,
                        count,
                        expected_binding_revision=expected_binding_revision,
                    )
            except RuntimeStateError as error:
                raise IdentityError(
                    f"Codex seat changed before legacy wake: {error}"
                ) from error
        try:
            with seat_shared_guard(
                project,
                lease.agent_id,
                lease.session_id,
                lease.revision,
            ):
                return self._wake_guarded(
                    project,
                    agent_id,
                    thread_id,
                    generation,
                    count,
                    expected_binding_revision=expected_binding_revision,
                )
        except (FenceRejected, RuntimeStateError) as error:
            raise IdentityError(
                f"Codex seat changed before wake: {error}"
            ) from error

    def _wake_guarded(
        self,
        project: Path,
        agent_id: str,
        thread_id: str,
        generation: str,
        count: int,
        *,
        expected_binding_revision,
    ) -> bool:
        # The API lacks an atomic only-if-idle primitive, so status can still
        # change between read and turn/start. Binding selection is stricter:
        # the binding-state lock serializes bind() against the accepted wake,
        # while a leased caller also holds the project claim lock shared.
        thread = self._refresh(project, thread_id)
        if status_type(thread) == "active":
            self.active_observed.add(thread_id)
            project_state = self.store.project_state(project)
            project_state.update(
                {
                    "phase": "WAIT_BUSY",
                    "waitingGeneration": generation,
                    "pendingCount": count,
                }
            )
            self.store.save()
            return False
        if status_type(thread) != "idle":
            raise IdentityError(f"thread became {status_type(thread)} before wake")
        trust_reason = self._hook_trust_gate(project)
        if trust_reason:
            raise HumanGate("hook_trust", trust_reason)
        inbox = project / ".roundtable" / "inbox" / agent_id / "new"
        with self.store.transaction():
            current_binding = self.store.bindings.get(str(project)) or {}
            if (
                current_binding.get("threadId") != thread_id
                or current_binding.get("bindingRevision")
                != expected_binding_revision
            ):
                raise IdentityError(
                    "binding changed before wake"
                )
            project_state = self.store.project_state(project)
            project_state.update(
                {
                    "phase": "STARTING",
                    "attemptedGeneration": generation,
                    "attemptedAt": utc_now(),
                    "retryAt": time.time() + 30,
                }
            )
            self.store.flush_transaction()
            result = self.client.request(
                "turn/start",
                {
                    "threadId": thread_id,
                    "clientUserMessageId": f"roundtable-wake:{generation}",
                    "input": [
                        {"type": "text", "text": WAKE_TEXT.format(inbox=inbox)}
                    ],
                },
            )
            wake_turn_id = (result.get("turn") or {}).get("id")
            project_state.update(
                {
                    "phase": "WAKE_ACTIVE",
                    "lastWakeGeneration": generation,
                    "lastWakeAt": utc_now(),
                    "lastWakeTurnId": wake_turn_id,
                    "lastWakeThreadId": thread_id,
                    "lastWakeBindingRevision": expected_binding_revision,
                    "pendingCount": count,
                    "retryAt": 0,
                    "lastError": None,
                }
            )
            self.store.flush_transaction()
        log_event(
            "wake_started",
            project=str(project),
            thread_id=thread_id,
            generation=generation,
            pending_count=count,
        )
        return True

    def _wake_terminal(self, thread_id: str, turn_id: str) -> dict | None:
        events = self.completions.get(thread_id) or []
        for event in list(events):
            if event.get("turnId") == turn_id:
                events.remove(event)
                return event
        recent = self.client.request(
            "thread/turns/list",
            {
                "threadId": thread_id,
                "limit": 20,
                "sortDirection": "desc",
                "itemsView": "notLoaded",
            },
        ).get("data") or []
        for turn in recent:
            if turn.get("id") == turn_id:
                status = turn.get("status")
                if status in {"completed", "interrupted", "failed"}:
                    return {"turnId": turn_id, "status": status}
                return None
        # The caller refreshes/resumes and confirms the thread is no longer
        # active first. Absence from bounded history is therefore ambiguous,
        # and retries only through the persisted backoff path.
        return {"turnId": turn_id, "status": "unknown-after-resume"}

    def _record_project_error(
        self,
        project: Path,
        pending_count: int,
        error: Exception,
        *,
        expected_binding: tuple[str, object] | None = None,
    ) -> ProjectResult:
        with self.store.transaction():
            if expected_binding is not None:
                expected_thread_id, expected_revision = expected_binding
                current_binding = self.store.bindings.get(str(project)) or {}
                if (
                    current_binding.get("threadId") != expected_thread_id
                    or current_binding.get("bindingRevision") != expected_revision
                ):
                    return ProjectResult(False, "binding changed before error record")
            project_state = self.store.project_state(project)
            project_state.update(
                {
                    "phase": (
                        "BACKOFF" if isinstance(error, RpcError) else "IDENTITY_ERROR"
                    ),
                    "retryAt": time.time() + 30,
                    "lastError": str(error),
                    "pendingCount": pending_count,
                }
            )
            self.store.flush_transaction()
        log_event("project_error", project=str(project), error=str(error))
        return ProjectResult(False, str(error))

    def step_project(self, project: Path) -> ProjectResult:
        project_state = self.store.project_state(project)
        if project_state.get("phase") == "BIND_QUARANTINED":
            return ProjectResult(
                False,
                "binding quarantined; waiting for replacement SessionStart request",
            )
        if (
            project_state.get("phase") == "IDENTITY_ERROR"
            and time.time() < safe_timestamp(project_state.get("retryAt"))
        ):
            return ProjectResult(False, "backoff")
        binding = self.store.bindings.get(str(project)) or {}
        bound_agent = binding.get("agent", "codex")
        try:
            generation, ids = pending_generation(project, bound_agent)
        except (IdentityError, OSError) as error:
            return self._record_project_error(project, 0, error)
        project_state = self.store.project_state(project)
        if generation is None:
            if project_state:
                project_state.clear()
                project_state["phase"] = "EMPTY"
                self.store.save()
            return ProjectResult(True, "empty")
        if project_state.get("phase") == "NEEDS_HUMAN":
            needs_human = project_state.get("needsHuman")
            reason = (
                needs_human.get("reason")
                if isinstance(needs_human, dict)
                else project_state.get("lastError")
            )
            return ProjectResult(
                False, f"needs human: {reason or 'manual recovery required'}"
            )

        retry_at = safe_timestamp(project_state.get("retryAt"))
        backing_off = time.time() < retry_at
        binding = self.store.bindings.get(str(project)) or {}
        bound_thread_id = binding.get("threadId")
        cached_thread = self.resumed.get(str(project)) or {}
        needs_resume = bool(
            bound_thread_id and cached_thread.get("id") != bound_thread_id
            and str(project) not in self.resume_attempted
        )
        if backing_off and not needs_resume:
            return ProjectResult(False, "backoff")

        # Resume/validate on every fresh app-server connection before applying
        # debounce state. This is what makes daemon restart recovery safe.
        try:
            thread = self._thread_for(project)
            thread_id = thread["id"]
        except (IdentityError, RpcError) as error:
            return self._record_project_error(project, len(ids), error)
        project_state = self.store.project_state(project)
        binding = self.store.bindings.get(str(project)) or {}
        if binding.get("agent") != bound_agent:
            return ProjectResult(False, "binding agent changed; rescan required")
        binding_revision = binding.get("bindingRevision")

        if backing_off:
            return ProjectResult(False, "backoff")
        wake_generation = project_state.get("lastWakeGeneration")
        if isinstance(wake_generation, str) and wake_generation:
            wake_turn_id = project_state.get("lastWakeTurnId")
            wake_thread_id = project_state.get("lastWakeThreadId") or thread_id
            wake_binding_revision = project_state.get("lastWakeBindingRevision")
            if wake_thread_id != thread_id:
                terminal = {"turnId": wake_turn_id, "status": "binding-changed"}
            else:
                try:
                    refreshed = self._refresh(project, thread_id)
                    if status_type(refreshed) == "active":
                        terminal = None
                    else:
                        terminal = (
                            self._wake_terminal(thread_id, wake_turn_id)
                            if wake_turn_id
                            else {"turnId": None, "status": "missing-turn-id"}
                        )
                except (IdentityError, RpcError) as error:
                    return self._record_project_error(
                        project,
                        len(ids),
                        error,
                        expected_binding=(thread_id, wake_binding_revision),
                    )
            if terminal is None:
                return ProjectResult(True, "generation already woken")
            terminal_status = terminal.get("status")
            if terminal_status == "interrupted":
                human_result = self._latch_pending_human_if_any(
                    project,
                    thread_id,
                    wake_generation,
                    wake_turn_id,
                    len(ids),
                    expected_binding_revision=wake_binding_revision,
                )
                if human_result is not None:
                    return human_result
            self._clear_pending_human_requests(project, thread_id, wake_turn_id)
            project_state = self.store.project_state(project)
            if terminal_status == "interrupted":
                try:
                    trust_reason = self._hook_trust_gate(project)
                except (IdentityError, RpcError) as error:
                    return self._record_project_error(
                        project,
                        len(ids),
                        error,
                        expected_binding=(thread_id, wake_binding_revision),
                    )
                if trust_reason:
                    return self._mark_needs_human(
                        project,
                        thread_id,
                        wake_generation,
                        wake_turn_id,
                        len(ids),
                        "hook_trust",
                        trust_reason,
                        expected_binding_revision=wake_binding_revision,
                    )
                breaker = project_state.get("breaker")
                if not isinstance(breaker, dict):
                    breaker = {}
                same_pair = (
                    breaker.get("generation") == wake_generation
                    and breaker.get("threadId") == thread_id
                )
                interrupted_count = (
                    safe_counter(breaker.get("interruptedUndrainedCount")) + 1
                    if same_pair
                    else 1
                )
                breaker_state = {
                    "generation": wake_generation,
                    "threadId": thread_id,
                    "interruptedUndrainedCount": interrupted_count,
                }
                project_state["breaker"] = breaker_state
                if interrupted_count >= INTERRUPTED_BREAKER_LIMIT:
                    return self._mark_needs_human(
                        project,
                        thread_id,
                        wake_generation,
                        wake_turn_id,
                        len(ids),
                        "interrupted_breaker",
                        f"{interrupted_count} consecutive interrupted wake turns "
                        "left the same inbox generation undrained",
                        expected_binding_revision=wake_binding_revision,
                        state_updates={"breaker": breaker_state},
                    )
            else:
                project_state.pop("breaker", None)
            retry_count = safe_counter(project_state.get("retryCount")) + 1
            delay = min(1800, 30 * (2 ** min(retry_count - 1, 6)))
            project_state.update(
                {
                    "phase": "BACKOFF",
                    "retryCount": retry_count,
                    "retryAt": time.time() + delay,
                    "lastError": (
                        f"wake turn {wake_turn_id} ended {terminal.get('status')} "
                        "with inbox still pending"
                    ),
                }
            )
            project_state.pop("lastWakeGeneration", None)
            project_state.pop("lastWakeTurnId", None)
            project_state.pop("lastWakeThreadId", None)
            project_state.pop("lastWakeBindingRevision", None)
            self.store.save()
            log_event(
                "wake_undrained",
                project=str(project),
                thread_id=thread_id,
                turn_id=wake_turn_id,
                status=terminal.get("status"),
                retry_seconds=delay,
            )
            return ProjectResult(False, f"wake undrained; retry in {delay}s")

        try:
            thread = self._refresh(project, thread_id)
            state = status_type(thread)
            if state == "active":
                self.active_observed.add(thread_id)
                project_state.update(
                    {
                        "phase": "WAIT_BUSY",
                        "waitingGeneration": generation,
                        "pendingCount": len(ids),
                    }
                )
                self.store.save()
                return ProjectResult(True, "waiting for turn/completed")
            if state != "idle":
                raise IdentityError(f"thread status is {state}, expected idle or active")

            waiting = project_state.get("phase") == "WAIT_BUSY"
            if (
                waiting
                and thread_id in self.active_observed
                and thread_id not in self.completed_threads
                and thread_id in self.subscribed_threads
            ):
                return ProjectResult(True, "idle observed; waiting for matching turn/completed")
            self.completed_threads.discard(thread_id)
            self.active_observed.discard(thread_id)
            started = self._wake(
                project,
                thread_id,
                generation,
                len(ids),
                expected_binding_revision=binding_revision,
            )
            return ProjectResult(True, "wake started" if started else "became busy before wake")
        except HumanGate as gate:
            return self._mark_needs_human(
                project,
                thread_id,
                generation,
                None,
                len(ids),
                gate.source,
                gate.reason,
                expected_binding_revision=binding_revision,
            )
        except (IdentityError, RpcError) as error:
            return self._record_project_error(
                project,
                len(ids),
                error,
                expected_binding=(thread_id, binding_revision),
            )

    def step(self, messages: list[dict] | None = None) -> list[ProjectResult]:
        self.store.reload()
        rebound = drain_bind_requests(
            self.client,
            self.store,
            self.projects,
            quarantined_projects=self.bind_quarantined,
        )
        for project in rebound:
            self.resumed.pop(project, None)
            self.resume_attempted.discard(project)
        self.consume_messages(messages or [])
        return [
            (
                ProjectResult(
                    False,
                    "binding quarantined; waiting for replacement SessionStart request",
                )
                if str(project) in self.bind_quarantined
                else self.step_project(project)
            )
            for project in self.projects
        ]


def discover_projects(explicit: list[str], *, warn: bool = True) -> list[Path]:
    paths: list[Path] = []
    if explicit:
        paths.extend(Path(value) for value in explicit)
    else:
        entries, warnings = load_project_registry()
        if warn:
            emit_registry_warnings(warnings, tool="rt-codex-wake")
        paths.extend(entry["root"] for entry in entries)
    projects = []
    seen = set()
    for path in paths:
        try:
            project = canonical_project(path)
        except IdentityError:
            if explicit:
                raise
            continue
        if str(project) not in seen and project_config_has_codex(project):
            seen.add(str(project))
            projects.append(project)
    return projects


def registry_stamp() -> tuple[int, int] | None:
    try:
        info = projects_registry_path().stat()
    except OSError:
        return None
    return info.st_mtime_ns, info.st_size


def acquire_singleton(lock: Path):
    """Hold a kernel lock; SIGKILL and crashes release it automatically."""
    lock.parent.mkdir(parents=True, exist_ok=True, mode=0o700)
    handle = None
    try:
        descriptor = os.open(lock, os.O_RDWR | os.O_CREAT, 0o600)
        handle = os.fdopen(descriptor, "r+")
        fcntl.flock(handle.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
    except (BlockingIOError, OSError) as error:
        if handle is not None:
            handle.close()
        raise CodexRuntimeError(f"bridge singleton lock is held: {lock}") from error
    handle.seek(0)
    handle.truncate()
    handle.write(f"{os.getpid()}\n")
    handle.flush()
    os.fsync(handle.fileno())
    return handle


def heartbeat(
    path: Path,
    projects: list[Path],
    socket_path: Path,
    last_rpc_ok_at: str | None,
    error: str | None,
) -> None:
    atomic_json(
        path,
        {
            "schema": "roundtable.codex-wake-heartbeat.v1",
            "pid": os.getpid(),
            "bridgeBuildFingerprint": BRIDGE_BUILD_FINGERPRINT,
            "heartbeatAt": utc_now(),
            "lastRpcOkAt": last_rpc_ok_at,
            "lastError": error,
            "socketPath": str(socket_path),
            "projects": [str(project) for project in projects],
        },
    )


def bind_command(args) -> int:
    project = canonical_project(Path(args.project or os.getcwd()))
    thread_id = args.thread_id or os.environ.get("CODEX_THREAD_ID")
    if not thread_id:
        raise IdentityError(
            "CODEX_THREAD_ID is unavailable; run bind from the target Codex turn"
        )
    require_validated_version()
    require_validated_daemon(args.socket)
    client = AppServerClient(args.socket)
    try:
        thread = validate_thread(project, read_thread(client, thread_id), thread_id)
        lease = _lease_environment(project)
        store = StateStore(args.state_file)
        if lease is None:
            try:
                with legacy_harness_guard(project, "codex"):
                    store.bind(project, thread)
            except RuntimeStateError as error:
                raise IdentityError(
                    f"Codex seat changed before legacy bind: {error}"
                ) from error
        else:
            try:
                with seat_shared_guard(
                    project,
                    lease.agent_id,
                    lease.session_id,
                    lease.revision,
                ) as current:
                    store.bind(project, thread, lease=current)
                    update_wake(
                        project,
                        current.agent_id,
                        current.session_id,
                        current.revision,
                        native_session_id=thread_id,
                    )
            except (FenceRejected, RuntimeStateError) as error:
                raise IdentityError(
                    f"Codex seat changed before bind: {error}"
                ) from error
        agent_id = lease.agent_id if lease is not None else "codex"
        print(f"bound project={project} agent={agent_id} thread={thread_id}")
        return 0
    finally:
        client.close()


def unbind_command(args) -> int:
    project = Path(args.project).expanduser().resolve()
    store = StateStore(args.state_file)
    removed = store.unbind(project)
    print(f"{'unbound' if removed else 'not bound'} project={project} agent=codex")
    return 0 if removed else 1


def run_command(args) -> int:
    try:
        projects = discover_projects(args.project)
    except (IdentityError, OSError) as error:
        log_event("bridge_disabled", error=str(error))
        print(f"rt-codex-wake: bridge disabled: {error}", file=sys.stderr)
        return 1 if args.once else 0
    if not projects and args.once:
        log_event("bridge_disabled", error="no configured Roundtable projects with a Codex agent")
        print("rt-codex-wake: no configured Roundtable projects; bridge disabled", file=sys.stderr)
        return 0
    lock = RUNTIME_DIR / "rt-codex-wake.lock"
    pid_file = RUNTIME_DIR / "rt-codex-wake.pid"
    heartbeat_file = RUNTIME_DIR / "rt-codex-wake-heartbeat.json"
    singleton = acquire_singleton(lock)
    atomic_json(pid_file.with_suffix(".json"), {"pid": os.getpid(), "startedAt": utc_now()})
    pid_file.write_text(f"{os.getpid()}\n")
    os.chmod(pid_file, 0o600)
    stopping = False

    def stop(_signum, _frame):
        nonlocal stopping
        stopping = True

    signal.signal(signal.SIGTERM, stop)
    signal.signal(signal.SIGINT, stop)
    store = StateStore(args.state_file)
    last_registry_stamp = registry_stamp() if not args.project else None
    client = None
    backoff = 1.0
    exit_code = 0
    last_rpc_ok = None
    last_error = None
    try:
        while not stopping:
            try:
                require_validated_version()
                require_validated_daemon(args.socket)
                client = AppServerClient(args.socket)
                bridge = WakeBridge(
                    client,
                    projects,
                    store,
                    auto_discover=getattr(args, "auto_discover", False),
                )
                messages = []
                while not stopping:
                    current_stamp = registry_stamp() if not args.project else None
                    if args.project or current_stamp != last_registry_stamp:
                        refreshed_projects = discover_projects(
                            args.project, warn=True
                        )
                        last_registry_stamp = current_stamp
                    else:
                        refreshed_projects = bridge.projects
                    if refreshed_projects != bridge.projects:
                        bridge.projects = refreshed_projects
                        projects = refreshed_projects
                        log_event(
                            "projects_reloaded",
                            projects=[str(project) for project in projects],
                        )
                    results = bridge.step(messages)
                    backoff = 1.0
                    exit_code = 0
                    last_rpc_ok = utc_now()
                    last_error = None
                    heartbeat(heartbeat_file, projects, args.socket, last_rpc_ok, None)
                    heartbeat_bound_seats(store, bridge.projects, results)
                    if args.once:
                        return 0 if all(result.ok for result in results) else 1
                    messages = client.drain_notifications(args.poll_seconds)
                break
            except (OSError, TimeoutError, CodexRuntimeError) as error:
                last_error = str(error)
                exit_code = 1
                retry_delay = 60.0 if isinstance(error, UnsupportedVersion) else backoff
                log_event(
                    "bridge_connection_error",
                    error=last_error,
                    retry_seconds=retry_delay,
                )
                heartbeat(heartbeat_file, projects, args.socket, last_rpc_ok, last_error)
                if args.once:
                    return 1
                deadline = time.monotonic() + retry_delay
                next_heartbeat = 0.0
                while not stopping and time.monotonic() < deadline:
                    now = time.monotonic()
                    if now >= next_heartbeat:
                        heartbeat(
                            heartbeat_file,
                            projects,
                            args.socket,
                            last_rpc_ok,
                            last_error,
                        )
                        next_heartbeat = now + 5.0
                    time.sleep(min(0.2, deadline - now))
                backoff = min(60.0, backoff * 2)
            finally:
                if client is not None:
                    try:
                        client.close()
                    except OSError:
                        pass
                    client = None
        return 0 if stopping else exit_code
    finally:
        for path in (pid_file, pid_file.with_suffix(".json")):
            try:
                path.unlink()
            except FileNotFoundError:
                pass
        fcntl.flock(singleton.fileno(), fcntl.LOCK_UN)
        singleton.close()


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="rt-codex-wake")
    parser.add_argument("--socket", type=Path, default=DEFAULT_SOCKET)
    parser.add_argument("--state-file", type=Path, default=RUNTIME_DIR / "rt-codex-wake-state.json")
    subparsers = parser.add_subparsers(dest="command", required=True)

    run = subparsers.add_parser("run")
    run.add_argument("--project", action="append", default=[])
    run.add_argument("--auto-discover", action="store_true")
    run.add_argument("--poll-seconds", type=float, default=5.0)
    run.add_argument("--once", action="store_true")

    bind = subparsers.add_parser("bind")
    bind.add_argument("project", nargs="?")
    bind.add_argument("--thread-id")

    unbind = subparsers.add_parser("unbind")
    unbind.add_argument("project")

    install = subparsers.add_parser("install")
    install.add_argument("--reload", action="store_true")
    install.add_argument("--auto-discover", action="store_true")
    return parser


def main() -> int:
    args = build_parser().parse_args()
    try:
        if args.command == "bind":
            return bind_command(args)
        if args.command == "unbind":
            return unbind_command(args)
        if args.command == "install":
            require_default_socket(args.socket)
            require_validated_version()
            path = install_launch_agent(
                WAKE_LABEL,
                wake_plist(
                    args.socket,
                    auto_discover=args.auto_discover,
                ),
                reload=args.reload,
            )
            print(f"installed {path}")
            return 0
        return run_command(args)
    except (IdentityError, CodexRuntimeError, OSError) as error:
        print(f"rt-codex-wake: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
