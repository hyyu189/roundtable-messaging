#!/usr/bin/env bash
# rt-watch-ensure: idempotent auto-start of rt-watch for current project.
#
# Called by agent SessionStart hooks. Safe to call concurrently.
# Outside a roundtable project it may print one advisory, but never binds/routes.
# Inside a project it does nothing when rt-watch is already alive.
# Starts a foreground rt-watch process in a dedicated cmux terminal surface.
#
# Exit codes:
#   0  rt-watch is alive after this call (was alive or just started)
#   0  not in a roundtable project (silent or one advisory; hooks don't fail)
#   2  could not acquire lock (another concurrent caller is starting it)

set -u

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"

# Discover project root (walk-up from PWD looking for .roundtable/agents.yaml).
# Honor ROUNDTABLE_PROJECT_DIR override.
discover_project() {
    if [[ -n "${ROUNDTABLE_PROJECT_DIR:-}" ]]; then
        [[ -f "$ROUNDTABLE_PROJECT_DIR/.roundtable/agents.yaml" ]] && {
            printf '%s' "$ROUNDTABLE_PROJECT_DIR"
            return 0
        }
        return 1
    fi
    local d="$PWD"
    while [[ "$d" != "/" ]]; do
        if [[ -f "$d/.roundtable/agents.yaml" ]]; then
            printf '%s' "$d"
            return 0
        fi
        d="$(dirname "$d")"
    done
    return 1
}

project="$(discover_project)" || {
    "$SCRIPT_DIR/rt-startup-advisory" 2>/dev/null || true
    exit 0
}

state_dir="$project/.roundtable"
lock_dir="$state_dir/locks/rt-watch-ensure.lock"
pid_file="$state_dir/rt-watch.pid"
log_file="$state_dir/rt-watch.log"
heartbeat_file="$state_dir/rt-watch.heartbeat"
surface_file="$state_dir/rt-watch.surface"
heartbeat_max_age=10

mkdir -p "$state_dir/locks"

# Atomic lock so 3 concurrent SessionStart hooks don't race-start 3 daemons.
mkdir "$lock_dir" 2>/dev/null || exit 2
trap 'rmdir "$lock_dir" 2>/dev/null' EXIT

is_rt_watch_pid() {
    local pid="$1" command
    command="$(ps -p "$pid" -o command= 2>/dev/null || true)"
    # Match any rt-watch process (not tied to a specific install dir)
    [[ "$command" == *"/rt-watch" || "$command" == *"/rt-watch "* ]]
}

# Already alive and making progress?
if [[ -f "$pid_file" ]]; then
    pid="$(cat "$pid_file" 2>/dev/null || true)"
    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
        if ! is_rt_watch_pid "$pid"; then
            echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) rt-watch pid file points to non-watch process pid=$pid; ignoring stale pid" >>"$log_file"
            rm -f "$pid_file"
        else
            now="$(date +%s)"
            if [[ -f "$heartbeat_file" ]]; then
                hb_mtime="$(stat -f %m "$heartbeat_file" 2>/dev/null || echo 0)"
                hb_age=$((now - hb_mtime))
                if [[ "$hb_age" -le "$heartbeat_max_age" ]]; then
                    exit 0
                fi
                echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) rt-watch stale heartbeat age=${hb_age}s pid=$pid; restarting" >>"$log_file"
            else
                pid_mtime="$(stat -f %m "$pid_file" 2>/dev/null || echo "$now")"
                pid_age=$((now - pid_mtime))
                if [[ "$pid_age" -le 30 ]]; then
                    exit 0
                fi
                echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) rt-watch missing heartbeat pid=$pid; restarting" >>"$log_file"
            fi
            kill "$pid" 2>/dev/null || true
            sleep 1
            kill -9 "$pid" 2>/dev/null || true
        fi
    fi
fi

# cmux CLI commands fail with Broken pipe from orphaned PID-1 daemons. Run the
# watcher inside a real cmux terminal surface so its process tree stays attached.
spawn_rt_watch() {
    cd "$project" || return 1
    echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) starting rt-watch" >>"$log_file"
    RT_PROJECT="$project" RT_LOG="$log_file" RT_PID_FILE="$pid_file" RT_SURFACE_FILE="$surface_file" RT_WATCH_BIN="$SCRIPT_DIR/rt-watch" python3 - <<'PY'
import json
import os
import re
import shlex
import subprocess
import sys

project = os.environ["RT_PROJECT"]
log_file = os.environ["RT_LOG"]
pid_file = os.environ["RT_PID_FILE"]
surface_file = os.environ["RT_SURFACE_FILE"]
watch = os.environ["RT_WATCH_BIN"]

def fail(message):
    with open(log_file, "a") as fh:
        fh.write(message + "\n")
    sys.exit(0)

try:
    identify = json.loads(subprocess.check_output(["cmux", "identify", "--json"], text=True))
except Exception as exc:
    fail(f"rt-watch-ensure: cmux identify failed; cannot start watcher surface: {exc}")

caller = identify.get("caller") or {}
workspace = caller.get("workspace_ref")
pane = caller.get("pane_ref")
if not workspace or not pane:
    fail("rt-watch-ensure: no cmux caller workspace/pane; cannot start watcher surface")

try:
    created = subprocess.check_output(
        [
            "cmux",
            "--id-format",
            "both",
            "new-surface",
            "--type",
            "terminal",
            "--workspace",
            workspace,
            "--pane",
            pane,
            "--working-directory",
            project,
            "--focus",
            "false",
        ],
        text=True,
    )
except Exception as exc:
    fail(f"rt-watch-ensure: cmux new-surface failed: {exc}")

surface = ""
for token in created.split():
    if token.startswith("surface:"):
        surface = token
        break
if not surface:
    fail(f"rt-watch-ensure: could not parse new watcher surface from: {created.strip()!r}")
surface_match = re.search(r"\bsurface:\d+\s+\(([0-9A-Fa-f-]+)\)", created)
workspace_match = re.search(r"\bworkspace:\d+\s+\(([0-9A-Fa-f-]+)\)", created)
surface_handle = surface_match.group(1) if surface_match else surface
workspace_handle = workspace_match.group(1) if workspace_match else workspace

with open(surface_file, "w") as fh:
    fh.write(surface_handle + "\n")
    fh.write(workspace_handle + "\n")

try:
    for _ in range(20):
        probe = subprocess.run(
            ["cmux", "read-screen", "--workspace", workspace_handle, "--surface", surface_handle, "--lines", "1"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        if probe.returncode == 0:
            break
        import time

        time.sleep(0.1)
    else:
        fail(f"rt-watch-ensure: watcher surface {surface} did not become readable")
except Exception as exc:
    fail(f"rt-watch-ensure: cmux read-screen failed for {surface}: {exc}")

title = f"rt-watch {os.path.basename(project)}"
script = (
    "cd {project} && "
    "export ROUNDTABLE_PROJECT_DIR={project} && "
    "printf '\\033]0;{title}\\007' && "
    "echo $$ > {pid_file} && "
    "exec {watch} >> {log_file} 2>&1"
).format(
    project=shlex.quote(project),
    title=title.replace("'", ""),
    pid_file=shlex.quote(pid_file),
    watch=shlex.quote(watch),
    log_file=shlex.quote(log_file),
)
command = "/bin/zsh -lc " + shlex.quote(script)

try:
    subprocess.check_call(
        ["cmux", "send", "--workspace", workspace_handle, "--surface", surface_handle, command],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    subprocess.check_call(
        ["cmux", "send-key", "--workspace", workspace_handle, "--surface", surface_handle, "enter"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
except Exception as exc:
    fail(f"rt-watch-ensure: cmux send failed for {surface}: {exc}")
PY
}

spawn_rt_watch

exit 0
