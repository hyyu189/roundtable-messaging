schema: roundtable.agents.v1
project: "."
# instances: one per running session. Identity comes from the harness launcher,
# never from a terminal surface. Optional cmux topology match/detect and legacy
# keyboard-submit settings may be added separately when that adapter is used.
agents:
  claude:
    harness: claude-code
    instances:
      - id: claude

  codex:
    harness: codex
    instances:
      - id: codex

  hermes:
    harness: hermes-agent
    instances:
      - id: hermes
